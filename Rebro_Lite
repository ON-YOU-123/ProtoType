                  <input type="number" className="level-input" style={{display: 'inline-block', width: '70px', marginLeft: '4px'}} value={currentLevel} onChange={e => setCurrentLevel(parseInt(e.target.value, 10) || 0)} step="50" />
                </div>
                {isSlopedPipe(currentPipeType) && (
                  <div style={{fontSize: '10px', color: '#c05621', marginTop: '4px'}}>勾配 {slopeRatioToText(SLOPE_DEFAULTS[currentPipeType])}<br/>(始点側)</div>
                )}
              </div>
              <div className="sidebar-section">
                <div className="sidebar-section-title">系統(クリックでハイライト)</div>
                {summary.pipeSystems.length === 0 ? (
                  <div style={{fontSize: '10px', color: '#888', padding: '4px'}}>配管が未配置</div>
                ) : (
                  <React.Fragment>
                    {highlightedPipeSystem && (
                      <div className="sidebar-item" onClick={() => setHighlightedPipeSystem(null)} style={{color: '#4299e1', fontWeight: 'bold'}}>
                        ◀ 全表示に戻す
                      </div>
                    )}
                    {summary.pipeSystems.map(sys => (
                      <div
                        key={sys.system}
                        className={`sidebar-item ${highlightedPipeSystem === sys.system ? 'active' : ''}`}
                        onClick={() => setHighlightedPipeSystem(highlightedPipeSystem === sys.system ? null : sys.system)}
                        title={sys.typesText}
                      >
                        <div style={{fontWeight: 'bold'}}>{sys.system}</div>
                        <div style={{fontSize: '10px', opacity: 0.8}}>{sys.count}本 / {Math.round(sys.totalLength)}mm</div>
                      </div>
                    ))}
                  </React.Fragment>
                )}
              </div>
              <div className="sidebar-section">
                <div className="sidebar-section-title">操作</div>
                <div className="sidebar-item" onClick={resetView}>表示リセット</div>
                <div className="sidebar-item" onClick={clearAll} style={{color: '#c53030'}}>配管 全クリア</div>
              </div>
            </React.Fragment>
          )}
        </div>

        <div className="canvas-wrap">
          <svg
            ref={svgRef}
            className={svgClass}
            viewBox={viewMode === 'iso' ? isoViewBox : viewBox}
            preserveAspectRatio="xMidYMid meet"
            onClick={viewMode === 'plan' ? handleSvgClick : undefined}
            onMouseMove={viewMode === 'plan' ? handleMouseMove : undefined}
            onMouseDown={viewMode === 'plan' ? handleSvgMouseDown : undefined}
            onMouseUp={viewMode === 'plan' ? handleSvgMouseUp : undefined}
            onMouseLeave={viewMode === 'plan' ? handleSvgMouseUp : undefined}
            onContextMenu={viewMode === 'plan' ? handleContextMenu : undefined}
            style={{cursor: viewMode === 'iso' ? 'default' : undefined}}
          >
            <defs>
              <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#eee" strokeWidth="1"/>
              </pattern>
              <pattern id="gridMajor" width="100" height="100" patternUnits="userSpaceOnUse">
                <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#ddd" strokeWidth="1"/>
              </pattern>
            </defs>
            {viewMode === 'plan' && (
            <React.Fragment>
            <rect x={view.x - 200} y={view.y - 200} width={view.w + 400} height={view.h + 400} fill="url(#grid)" />
            <rect x={view.x - 200} y={view.y - 200} width={view.w + 400} height={view.h + 400} fill="url(#gridMajor)" />

            {frames.map(fr => {
              if (!visibleFrameTypes[fr.type]) return null;
              const isSelected = fr.id === selectedFrameId;
              return (
                <g key={fr.id} style={{cursor: mode === 'select' ? 'pointer' : 'default'}} onClick={(e) => handleFrameClick(fr.id, e)}>
                  <rect x={fr.x} y={fr.y} width={fr.w} height={fr.h} fill={FRAME_COLORS[fr.type]} fillOpacity={isSelected ? 0.8 : 0.5} stroke={isSelected ? '#f6e05e' : '#666'} strokeWidth={isSelected ? 3 : 1}/>
                  <text x={fr.x + fr.w / 2} y={fr.y + fr.h / 2 + 4} textAnchor="middle" fontSize="10" fill="#444" style={{pointerEvents: 'none'}}>{fr.name}</text>
                </g>
              );
            })}

            {mode === 'frame' && frameType && frameStart && mousePos && (() => {
              const minX = Math.min(frameStart.x, mousePos.x);
              const minY = Math.min(frameStart.y, mousePos.y);
              const w = Math.abs(mousePos.x - frameStart.x);
              const h = Math.abs(mousePos.y - frameStart.y);
              if (w === 0 || h === 0) return null;
              return <rect x={minX} y={minY} width={w} height={h} fill={FRAME_COLORS[frameType]} fillOpacity="0.3" stroke={FRAME_COLORS[frameType]} strokeWidth="2" strokeDasharray="6 4"/>;
            })()}
            {mode === 'frame' && frameStart && (
              <circle cx={frameStart.x} cy={frameStart.y} r="5" fill="#f6e05e" stroke="#888" strokeWidth="2"/>
            )}

            {/* 機器の描画 */}
            {equipments.map(eq => {
              if (!visibleEquipmentTypes[eq.equipType]) return null;
              const def = EQUIPMENT_DEFS[eq.equipType];
              const isSelected = eq.id === selectedEquipmentId;
              const color = def ? def.color : '#888';
              return (
                <g key={eq.id} style={{cursor: mode === 'select' ? 'pointer' : 'default'}} onClick={(e) => handleEquipmentClick(eq.id, e)}>
                  <rect
                    x={eq.x} y={eq.y} width={eq.w} height={eq.h}
                    fill={color}
                    fillOpacity={isSelected ? 0.85 : 0.6}
                    stroke={isSelected ? '#f6e05e' : '#444'}
                    strokeWidth={isSelected ? 3 : 1.5}
                  />
                  <text x={eq.x + eq.w / 2} y={eq.y + eq.h / 2 + 3} textAnchor="middle" fontSize="9" fill="#fff" fontWeight="bold" style={{pointerEvents: 'none'}}>
                    {eq.name}
                  </text>
                  {/* 接続ポイント:四辺の中点 */}
                  <circle cx={eq.x + eq.w / 2} cy={eq.y} r="2.5" fill="#fff" stroke={color} strokeWidth="1.2" style={{pointerEvents: 'none'}}/>
                  <circle cx={eq.x + eq.w / 2} cy={eq.y + eq.h} r="2.5" fill="#fff" stroke={color} strokeWidth="1.2" style={{pointerEvents: 'none'}}/>
                  <circle cx={eq.x} cy={eq.y + eq.h / 2} r="2.5" fill="#fff" stroke={color} strokeWidth="1.2" style={{pointerEvents: 'none'}}/>
                  <circle cx={eq.x + eq.w} cy={eq.y + eq.h / 2} r="2.5" fill="#fff" stroke={color} strokeWidth="1.2" style={{pointerEvents: 'none'}}/>
                </g>
              );
            })}

            {/* 機器配置プレビュー */}
            {mode === 'equipment' && equipmentType && mousePos && (() => {
              const def = EQUIPMENT_DEFS[equipmentType];
              if (!def) return null;
              const x = mousePos.x - def.width / 2;
              const y = mousePos.y - def.height / 2;
              return (
                <rect x={x} y={y} width={def.width} height={def.height} fill={def.color} fillOpacity="0.3" stroke={def.color} strokeWidth="2" strokeDasharray="4 3"/>
              );
            })()}

            {edges.map(edge => {
              if (!visiblePipeTypes[edge.pipeType]) return null;
              const n1 = nodes.find(n => n.id === edge.startId);
              const n2 = nodes.find(n => n.id === edge.endId);
              if (!n1 || !n2) return null;
              const isClashed = (mode === 'clash' || mode === 'select') && clashedEdgeIds.has(edge.id);
              const isSelected = edge.id === selectedEdgeId;
              const color = isClashed ? '#e53e3e' : PIPE_COLORS[edge.pipeType];
              // 系統ハイライト:該当系統でなければ薄く
              const isDimmed = highlightedPipeSystem !== null && edge.system !== highlightedPipeSystem;
              const baseOpacity = isClashed ? 1 : 0.85;
              const finalOpacity = isDimmed ? 0.18 : baseOpacity;
              return (
                <line
                  key={edge.id}
                  x1={n1.x} y1={n1.y} x2={n2.x} y2={n2.y}
                  stroke={color}
                  strokeWidth={isSelected ? 8 : 6}
                  strokeLinecap="round"
                  style={{cursor: mode === 'select' ? 'pointer' : 'default'}}
                  onClick={(e) => handleEdgeClick(edge.id, e)}
                  opacity={finalOpacity}
                />
              );
            })}

            {/* ダクトの描画(実寸スケールの帯として) */}
            {ductEdges.map(de => {
              if (!visibleDuctTypes[de.ductType]) return null;
              const n1 = ductNodes.find(n => n.id === de.startId);
              const n2 = ductNodes.find(n => n.id === de.endId);
              if (!n1 || !n2) return null;
              const isClashed = (mode === 'clash' || mode === 'select') && clashedDuctEdgeIds.has(de.id);
              const isSelected = de.id === selectedDuctEdgeId;
              const color = isClashed ? '#e53e3e' : DUCT_COLORS[de.ductType];
              const widthMM = de.shape === 'round' ? de.size.d : de.size.w;
              const widthPX = widthMM / SCALE_MM_PER_PX;
              const dx = n2.x - n1.x;
              const dy = n2.y - n1.y;
              const isHorizontal = Math.abs(dx) >= Math.abs(dy);
              // 帯状の矩形を生成
              let rectX, rectY, rectW, rectH;
              if (isHorizontal) {
                rectX = Math.min(n1.x, n2.x);
                rectW = Math.abs(dx);
                rectY = n1.y - widthPX / 2;
                rectH = widthPX;
              } else {
                rectY = Math.min(n1.y, n2.y);
                rectH = Math.abs(dy);
                rectX = n1.x - widthPX / 2;
                rectW = widthPX;
              }
              // 系統ハイライト
              const isDimmed = highlightedDuctSystem !== null && de.system !== highlightedDuctSystem;
              const baseFillOpacity = isClashed ? 0.55 : 0.35;
              const finalFillOpacity = isDimmed ? 0.08 : baseFillOpacity;
              const finalStrokeOpacity = isDimmed ? 0.2 : 1;
              return (
                <g key={de.id} style={{cursor: mode === 'select' ? 'pointer' : 'default'}} onClick={(e) => handleDuctEdgeClick(de.id, e)}>
                  <rect
                    x={rectX} y={rectY} width={rectW} height={rectH}
                    fill={color}
                    fillOpacity={finalFillOpacity}
                    stroke={isSelected ? '#f6e05e' : color}
                    strokeWidth={isSelected ? 3 : 1.2}
                    strokeOpacity={finalStrokeOpacity}
                    strokeDasharray={de.shape === 'round' ? '4 2' : null}
                  />
                </g>
              );
            })}

            {/* ダクト描画中のプレビュー */}
            {mode === 'duct' && drawingDuctFromId && mousePos && (() => {
              const from = ductNodes.find(n => n.id === drawingDuctFromId);
              if (!from) return null;
              const widthMM = currentDuctShape === 'round' ? currentDuctSize.d : currentDuctSize.w;
              const widthPX = widthMM / SCALE_MM_PER_PX;
              const dx = mousePos.x - from.x;
              const dy = mousePos.y - from.y;
              const isHorizontal = Math.abs(dx) >= Math.abs(dy);
              let rectX, rectY, rectW, rectH;
              if (isHorizontal) {
                rectX = Math.min(from.x, mousePos.x);
                rectW = Math.abs(dx);
                rectY = from.y - widthPX / 2;
                rectH = widthPX;
              } else {
                rectY = Math.min(from.y, mousePos.y);
                rectH = Math.abs(dy);
                rectX = from.x - widthPX / 2;
                rectW = widthPX;
              }
              if (rectW === 0 && rectH === 0) return null;
              return (
                <rect
                  x={rectX} y={rectY} width={rectW} height={rectH}
                  fill={DUCT_COLORS[currentDuctType]}
                  fillOpacity="0.2"
                  stroke={DUCT_COLORS[currentDuctType]}
                  strokeWidth="1.5"
                  strokeDasharray="6 4"
                />
              );
            })()}
            {drawingDuctFromId && (() => {
              const from = ductNodes.find(n => n.id === drawingDuctFromId);
              if (!from) return null;
              return <circle cx={from.x} cy={from.y} r="10" fill="none" stroke="#f6e05e" strokeWidth="3"/>;
            })()}

            {/* ダクトの継手ノード */}
            {ductNodes.map(node => {
              const fitType = ductNodeFittingTypes[node.id];
              if (!fitType || fitType === 'isolated') return null;
              const connectedEdge = ductEdges.find(e => e.startId === node.id || e.endId === node.id);
              if (!connectedEdge || !visibleDuctTypes[connectedEdge.ductType]) return null;
              const color = DUCT_COLORS[connectedEdge.ductType];
              let symbol;
              if (fitType === 'elbow') symbol = <circle cx={node.x} cy={node.y} r="6" fill={color} stroke="#fff" strokeWidth="2"/>;
              else if (fitType === 'tee') symbol = (<g><circle cx={node.x} cy={node.y} r="8" fill={color} stroke="#fff" strokeWidth="2"/><text x={node.x} y={node.y + 3} textAnchor="middle" fontSize="9" fill="#fff" fontWeight="bold" style={{pointerEvents: 'none'}}>T</text></g>);
              else if (fitType === 'cross') symbol = (<g><rect x={node.x - 7} y={node.y - 7} width="14" height="14" fill={color} stroke="#fff" strokeWidth="2"/><text x={node.x} y={node.y + 3} textAnchor="middle" fontSize="9" fill="#fff" fontWeight="bold" style={{pointerEvents: 'none'}}>+</text></g>);
              else if (fitType === 'end') symbol = <circle cx={node.x} cy={node.y} r="4" fill="#fff" stroke={color} strokeWidth="2"/>;
              else symbol = <circle cx={node.x} cy={node.y} r="3" fill={color}/>;
              return <g key={node.id}>{symbol}</g>;
            })}

            {selectedEdge && (() => {
              const n1 = nodes.find(n => n.id === selectedEdge.startId);
              const n2 = nodes.find(n => n.id === selectedEdge.endId);
              if (!n1 || !n2) return null;
              return <line x1={n1.x} y1={n1.y} x2={n2.x} y2={n2.y} stroke="#f6e05e" strokeWidth="14" strokeLinecap="round" opacity="0.5" style={{pointerEvents: 'none'}}/>;
            })()}

            {drawingFromId && mousePos && (() => {
              const from = nodes.find(n => n.id === drawingFromId);
              if (!from) return null;
              return <line x1={from.x} y1={from.y} x2={mousePos.x} y2={mousePos.y} stroke={PIPE_COLORS[currentPipeType]} strokeWidth="6" strokeDasharray="6 4" opacity="0.5"/>;
            })()}

            {nodes.map(node => {
              const fitType = nodeFittingTypes[node.id];
              if (!fitType || fitType === 'isolated') return null;
              const connectedEdge = edges.find(e => e.startId === node.id || e.endId === node.id);
              if (!connectedEdge || !visiblePipeTypes[connectedEdge.pipeType]) return null;
              const color = PIPE_COLORS[connectedEdge.pipeType];
              let symbol;
              if (fitType === 'elbow') symbol = <circle cx={node.x} cy={node.y} r="6" fill={color} stroke="#fff" strokeWidth="2"/>;
              else if (fitType === 'tee') symbol = (<g><circle cx={node.x} cy={node.y} r="8" fill="#38a169" stroke="#fff" strokeWidth="2"/><text x={node.x} y={node.y + 3} textAnchor="middle" fontSize="9" fill="#fff" fontWeight="bold" style={{pointerEvents: 'none'}}>T</text></g>);
              else if (fitType === 'cross') symbol = (<g><rect x={node.x - 7} y={node.y - 7} width="14" height="14" fill="#dd6b20" stroke="#fff" strokeWidth="2"/><text x={node.x} y={node.y + 3} textAnchor="middle" fontSize="9" fill="#fff" fontWeight="bold" style={{pointerEvents: 'none'}}>+</text></g>);
              else if (fitType === 'end') symbol = <circle cx={node.x} cy={node.y} r="4" fill="#fff" stroke={color} strokeWidth="2"/>;
              else symbol = <circle cx={node.x} cy={node.y} r="3" fill={color}/>;
              return <g key={node.id}>{symbol}</g>;
            })}

            {drawingFromId && (() => {
              const from = nodes.find(n => n.id === drawingFromId);
              if (!from) return null;
              return <circle cx={from.x} cy={from.y} r="10" fill="none" stroke="#f6e05e" strokeWidth="3"/>;
            })()}

            {(mode === 'clash' || mode === 'select') && clashes.map(clash => {
              const isClearance = clash.clashKind === 'clearance';
              const color = isClearance ? '#3182ce' : '#c53030';
              const symbol = isClearance ? '◆' : '⚠';
              return (
