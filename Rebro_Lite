    ]
  }
};

const SAMPLES = [SAMPLE_1, SAMPLE_2];

// ===== ユーティリティ =====
// 2つの矩形(AABB)が重なるか判定。重なる条件は4軸全てで投影が重なること
// 用途: 配管・ダクト・躯体・機器の平面での干渉粗判定
function aabbIntersect(a, b) {
  return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
}

// 2つの高さ範囲(low〜high)が重なるか判定
// 用途: 平面で重なる要素が3D高さ方向でも実際に干渉するかを確認
function heightOverlap(a, b) {
  return a.low < b.high && a.high > b.low;
}
// a が b に完全に内包されているか(a.low >= b.low かつ a.high <= b.high)
// 用途: 配管が梁のせいの中に完全に収まる場合のスリーブ判定
function heightFullyContained(a, b) {
  return a.low >= b.low && a.high <= b.high;
}

// 配管の AABB(軸並行バウンディングボックス)を計算
// 線分(p1→p2)に厚みを加えて矩形にする。thickness は描画上の線太さに対応
// 用途: 平面での干渉判定の前段としての粗い当たり判定
function segmentAABB(p1, p2, thickness = 8) {
  const minX = Math.min(p1.x, p2.x) - thickness / 2;
  const minY = Math.min(p1.y, p2.y) - thickness / 2;
  const maxX = Math.max(p1.x, p2.x) + thickness / 2;
  const maxY = Math.max(p1.y, p2.y) + thickness / 2;
  return { x: minX, y: minY, w: maxX - minX, h: maxY - minY };
}

// ダクトの AABB を計算
// 配管と違い、ダクトは進行方向に直交する方向にダクト幅を持つので、その分の厚みを持たせる
// shape: 'rect' | 'round'、size: { w, h } or { d }(mm単位)
function ductAABB(p1, p2, shape, size) {
  // ピクセル単位のダクト幅(平面で見えるダクトの厚み = W または直径)
  const widthMM = shape === 'round' ? size.d : size.w;
  const widthPX = widthMM / SCALE_MM_PER_PX;
  // 進行方向(水平/垂直)を判定し、その直交方向に widthPX/2 のマージンを取る
  const dx = p2.x - p1.x;
  const dy = p2.y - p1.y;
  const isHorizontal = Math.abs(dx) >= Math.abs(dy);
  let minX, minY, maxX, maxY;
  if (isHorizontal) {
    // 水平ダクト:Y方向にダクト幅を展開
    minX = Math.min(p1.x, p2.x);
    maxX = Math.max(p1.x, p2.x);
    minY = Math.min(p1.y, p2.y) - widthPX / 2;
    maxY = Math.max(p1.y, p2.y) + widthPX / 2;
  } else {
    // 垂直ダクト:X方向にダクト幅を展開
    minX = Math.min(p1.x, p2.x) - widthPX / 2;
    maxX = Math.max(p1.x, p2.x) + widthPX / 2;
    minY = Math.min(p1.y, p2.y);
    maxY = Math.max(p1.y, p2.y);
  }
  return { x: minX, y: minY, w: maxX - minX, h: maxY - minY };
}

// ダクトの高さ範囲を計算(中心高さ ± H/2 または直径/2)
// 角ダクトはH(高さ)、丸ダクトは直径を使用
function ductHeightRange(level, shape, size) {
  const heightMM = shape === 'round' ? size.d : size.h;
  const half = heightMM / 2;
  return { low: level - half, high: level + half };
}

// ピクセル空間でのユークリッド距離
function distance(p1, p2) {
  return Math.sqrt(Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2));
}

// ピクセル距離を実寸mmに変換(描画上の距離 → 実測距離)
// 用途: 配管長の表示、勾配計算、Excel出力用の長さ集計
function distanceMM(p1, p2) {
  return distance(p1, p2) * SCALE_MM_PER_PX;
}

// 座標をスナップグリッドに丸める(クリックした位置を最寄りのグリッド点に揃える)
// 用途: 配管・ダクト・躯体の頂点をきれいなピッチに揃える
function snapToGrid(coord, gridSize = SNAP_PX) {
  return Math.round(coord / gridSize) * gridSize;
}

// 配管・ダクトの描画を直角(水平または垂直)に補正する関数
// 前点と現在のマウス位置のXY差を比較し、長い方の軸に沿って引く
// 用途: 設備配管は水平/垂直が基本なので、自由角度ではなく直角に強制する
function orthogonalize(prev, current) {
  const dx = Math.abs(current.x - prev.x);
  const dy = Math.abs(current.y - prev.y);
  // X方向への変位が大きければ水平、そうでなければ垂直
  if (dx > dy) return { x: current.x, y: prev.y };
  return { x: prev.x, y: current.y };
}

// 画面上のマウス座標を SVG のワールド座標に変換
// SVG の viewBox との対応で計算
// 画面上のマウス座標を SVG のワールド座標に変換
// preserveAspectRatio="xMidYMid meet" を考慮し、レターボックス分のオフセットを補正する。
// 「meet」はSVGがビューポートに収まるように viewBox の比率を維持(余白が上下または左右に出る)。
function screenToWorld(e, svgRef, view) {
  const rect = svgRef.current.getBoundingClientRect();
  // ビューポート(画面表示領域)の比率
  const viewportRatio = rect.width / rect.height;
  const viewBoxRatio = view.w / view.h;
  let scale, offsetX, offsetY;
  if (viewportRatio > viewBoxRatio) {
    // ビューポートが横長 → SVGは縦方向いっぱい、横にレターボックス
    scale = rect.height / view.h;
    offsetX = (rect.width - view.w * scale) / 2;
    offsetY = 0;
  } else {
    // ビューポートが縦長(または同比率)→ SVGは横方向いっぱい、上下にレターボックス
    scale = rect.width / view.w;
    offsetX = 0;
    offsetY = (rect.height - view.h * scale) / 2;
  }
  // クライアント座標 → SVG内のピクセル座標 → viewBox 座標
  const localX = e.clientX - rect.left - offsetX;
  const localY = e.clientY - rect.top - offsetY;
  return { x: view.x + localX / scale, y: view.y + localY / scale };
}

// 口径文字列(例: 'φ50')を mm 数値に変換
function diameterToMM(d) { return parseInt(d.replace('φ', ''), 10); }

// 配管の高さ範囲を計算
// 配管中心レベル ± 半径(口径の1/2)で範囲を求める
// 始点と終点でレベルが違う場合(勾配あり)は両方の値を考慮
// 用途: 干渉判定での「3D高さでの重なり」検証
function pipeHeightRange(startLevel, endLevel, diameter) {
  const radius = diameterToMM(diameter) / 2;
  const minLv = Math.min(startLevel, endLevel);
  const maxLv = Math.max(startLevel, endLevel);
  return { low: minLv - radius, high: maxLv + radius };
}

// 配管の「保温厚+施工離隔」を含む拡張高さ範囲
// extraMM 分だけ上下に拡張する。離隔考慮の干渉判定で使用
function pipeHeightRangeExpanded(startLevel, endLevel, diameter, extraMM) {
  const base = pipeHeightRange(startLevel, endLevel, diameter);
  return { low: base.low - extraMM, high: base.high + extraMM };
}

// 配管の「保温厚+施工離隔」の合計値(mm)を取得
// 配管エッジから値を取得、未設定なら管種別デフォルトを使用
function pipeExtraMM(edge) {
  const insulation = (edge.insulation !== undefined) ? edge.insulation : (INSULATION_DEFAULTS[edge.pipeType] || 0);
  const clearance = (edge.clearance !== undefined) ? edge.clearance : PIPE_CLEARANCE_DEFAULT;
  return insulation + clearance;
}

// ダクトの離隔(mm)を取得
function ductExtraMM(edge) {
  return (edge.clearance !== undefined) ? edge.clearance : DUCT_CLEARANCE_DEFAULT;
}

// 勾配のある配管の終点レベルを計算
// startLevel: 始点のFL値(mm)、slopeDivisor: 勾配の分母(50なら1/50)、lengthMM: 配管長(実寸mm)
// 流下方向に下がるので、終点 = 始点 - (配管長 / 分母)
function calcEndLevel(startLevel, slopeDivisor, lengthMM) {
  if (!slopeDivisor) return startLevel;
  const drop = lengthMM / slopeDivisor;
  return Math.round(startLevel - drop);
}

// 勾配の分母から表示文字列を作る(例: 50 → "1/50 (2.0%)")
function slopeRatioToText(divisor) {
  if (!divisor || divisor === 0) return '水平';
  const pct = (100 / divisor).toFixed(1);
  return `1/${divisor} (${pct}%)`;
}

// 勾配を持つ配管種かどうか(排水・ドレンのみ流下勾配が必要)
function isSlopedPipe(pipeType) {
  return pipeType === '排水' || pipeType === 'ドレン';
}

// ===== メインコンポーネント =====
function App() {
  // ===== モード管理 =====
  // 作業モード:'draw'(配管)/ 'duct'(ダクト)/ 'frame'(躯体)/ 'equipment'(機器)/
  //            'select'(選択)/ 'clash'(干渉)/ 'summary'(集計)
  const [mode, setMode] = useState('draw');

  // ===== プロジェクト管理関連 =====
  const [projectName, setProjectName] = useState('新規プロジェクト');
  const [projectId, setProjectId] = useState(null); // 保存済みなら ID あり、未保存なら null
  const [menuOpen, setMenuOpen] = useState(false);
  const [modalType, setModalType] = useState(null); // null | 'load'(読込) | 'samples'(サンプル選択)
  const [savedProjects, setSavedProjects] = useState([]); // localStorage から読んだプロジェクト一覧
  const [toast, setToast] = useState(null); // 操作完了の通知メッセージ

  // ===== ドメインデータ =====
  // 配管:ノード(節点)とエッジ(区間)のグラフ構造
  const [nodes, setNodes] = useState([]);
  const [edges, setEdges] = useState([]);
  // ダクト:配管と独立したグラフ(設備設計の実務で衛生系と空調系は別管理が自然)
  const [ductNodes, setDuctNodes] = useState([]);
  const [ductEdges, setDuctEdges] = useState([]);
  // 躯体(梁・柱):建築構造体
  const [frames, setFrames] = useState(INITIAL_FRAMES);
  // 機器:室内機・ポンプ・AHU など
  const [equipments, setEquipments] = useState([]);

  // ===== Undo履歴 =====
  // ドメインデータの変更操作前にスナップショットを保存し、Ctrl+Z または戻るボタンで1つ前の状態に戻す
  // 履歴対象:nodes, edges, ductNodes, ductEdges, frames, equipments, projectName
  // 非対象:選択、ビュー、レイヤー、モード切替、描画途中の中間状態
  // 上限:50件(古いものから順に破棄)
  const [history, setHistory] = useState([]);
  const HISTORY_LIMIT = 50;

  // 現在のドメインデータを history に push する
  // ドメインデータを変更する操作の「直前」に呼ぶ
  // 引数 currentState は省略可能。省略時は現在の state を読む(useState 値は最新を参照できる)
  const pushHistory = () => {
    setHistory(prev => {
      const snapshot = {
        nodes: nodes.slice(),
        edges: edges.slice(),
        ductNodes: ductNodes.slice(),
        ductEdges: ductEdges.slice(),
        frames: frames.slice(),
        equipments: equipments.slice(),
        projectName,
      };
      const next = [...prev, snapshot];
      if (next.length > HISTORY_LIMIT) next.shift(); // 古いものから破棄
      return next;
    });
  };

  // history をすべてクリア(プロジェクト切り替え時など)
  const clearHistory = () => setHistory([]);

  // 1つ前の状態に戻す(履歴がなければ何もしない)
  const undo = () => {
    setHistory(prev => {
      if (prev.length === 0) return prev;
      const snapshot = prev[prev.length - 1];
      setNodes(snapshot.nodes);
      setEdges(snapshot.edges);
      setDuctNodes(snapshot.ductNodes);
      setDuctEdges(snapshot.ductEdges);
      setFrames(snapshot.frames);
      setEquipments(snapshot.equipments);
      setProjectName(snapshot.projectName);
      // 選択・描画中の状態もクリア(復元データと矛盾しないように)
      setSelectedEdgeId(null);
      setSelectedDuctEdgeId(null);
      setSelectedFrameId(null);
      setSelectedEquipmentId(null);
      setDrawingFromId(null);
      setDrawingDuctFromId(null);
      setFrameStart(null);
      return prev.slice(0, -1);
    });
  };

  // ===== 描画中の状態 =====
  // 配管描画中の起点ノードID(null なら未描画中)
  const [drawingFromId, setDrawingFromId] = useState(null);
  // マウスの現在位置(描画プレビューとヒント表示用)
  const [mousePos, setMousePos] = useState(null);

  // ===== 配管描画の設定 =====
  const [currentPipeType, setCurrentPipeType] = useState('給水');
  const [currentDiameter, setCurrentDiameter] = useState('φ50');
  const [currentLevel, setCurrentLevel] = useState(DEFAULT_PIPE_LEVEL);

  // ===== ダクト描画の設定 =====
  const [currentDuctType, setCurrentDuctType] = useState('給気');
  const [currentDuctShape, setCurrentDuctShape] = useState('rect'); // 'rect' = 角ダクト / 'round' = 丸ダクト
  const [currentDuctSize, setCurrentDuctSize] = useState({ w: 300, h: 200 }); // 角:{w,h} mm、丸:{d} mm
  const [currentDuctLevel, setCurrentDuctLevel] = useState(2500);

  // ダクト描画中の起点ノードID(配管とは別グラフなので別管理)
  const [drawingDuctFromId, setDrawingDuctFromId] = useState(null);

  // ===== 躯体描画の状態 =====
  const [frameType, setFrameType] = useState(null); // 'beam' or 'column' or null
  const [frameStart, setFrameStart] = useState(null); // 矩形の1点目

  // ===== 機器配置の状態 =====
  const [equipmentType, setEquipmentType] = useState(null);

  // ===== 選択状態 =====
  // 同時に複数選択できないように、各種別ごとに排他的に管理
  const [selectedEdgeId, setSelectedEdgeId] = useState(null);
  const [selectedDuctEdgeId, setSelectedDuctEdgeId] = useState(null);
  const [selectedFrameId, setSelectedFrameId] = useState(null);
  const [selectedEquipmentId, setSelectedEquipmentId] = useState(null);

  // ===== レイヤ(可視化制御) =====
  // 種別ごとに表示/非表示を切り替え可能(右パネルから操作)
  const [visiblePipeTypes, setVisiblePipeTypes] = useState({
    '給水': true, '排水': true, '冷温水': true, 'ドレン': true, '電気': true
  });
  const [visibleDuctTypes, setVisibleDuctTypes] = useState({
    '給気': true, '還気': true, '排気': true, '外気': true
  });
  // 躯体は梁/柱を独立制御(設備設計者は柱と梁を別に意識する)
  const [visibleFrameTypes, setVisibleFrameTypes] = useState({
    'beam': true, 'column': true,
  });
  // 機器は種別ごと(衛生と空調は別業者が施工することが多く、業者別表示に対応)
  const [visibleEquipmentTypes, setVisibleEquipmentTypes] = useState({
    'indoor': true, 'pump': true, 'ahu': true,
  });

  // ===== 系統ハイライト =====
  // ある系統だけ強調表示、他は薄く表示(配管とダクトを独立にハイライト可能)
  const [highlightedPipeSystem, setHighlightedPipeSystem] = useState(null);
  const [highlightedDuctSystem, setHighlightedDuctSystem] = useState(null);

  // ===== ビュー(SVG表示範囲)=====
  const [view, setView] = useState(INITIAL_VIEW);
  const [isPanning, setIsPanning] = useState(false);
  const [panStart, setPanStart] = useState(null);

  // ビューモード:'plan' = 平面図 / 'iso' = アイソメ図(等角投影、確認専用)
  const [viewMode, setViewMode] = useState('plan');

  const svgRef = useRef(null);
  const fileInputRef = useRef(null);

  const zoomLevel = INITIAL_VIEW.w / view.w;

  // トースト表示
  const showToast = (msg, type = 'success') => {
    setToast({ msg, type });
    setTimeout(() => setToast(null), 2500);
  };

  // 保存済みプロジェクト一覧をlocalStorageから読み込む
  const loadProjectList = () => {
    try {
      const json = localStorage.getItem(LS_PROJECT_LIST);
      const list = json ? JSON.parse(json) : [];
      setSavedProjects(list);
      return list;
    } catch (e) {
      console.error(e);
      return [];
    }
  };

  useEffect(() => {
    loadProjectList();
  }, []);

  // 現在の状態をシリアライズ
  const getCurrentData = () => ({
    projectName,
    frames,
    nodes,
    edges,
    ductNodes,
    ductEdges,
    equipments,
  });

  // データをstateに反映
  const loadData = (data) => {
    setProjectName(data.projectName || '無題プロジェクト');
    setFrames(data.frames || []);
    setNodes(data.nodes || []);
    setEdges(data.edges || []);
    setDuctNodes(data.ductNodes || []);
    setDuctEdges(data.ductEdges || []);
    setEquipments(data.equipments || []);
    setSelectedEdgeId(null);
    setSelectedDuctEdgeId(null);
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
    setDrawingFromId(null);
    setDrawingDuctFromId(null);
    setView(INITIAL_VIEW);
    clearHistory(); // 別プロジェクトに切り替えるので履歴も破棄
  };

  // 保存
  const saveProject = () => {
    try {
      const id = projectId || `p${Date.now()}`;
      const savedAt = new Date().toISOString();
      const data = getCurrentData();
      localStorage.setItem(LS_PROJECT_PREFIX + id, JSON.stringify(data));
      // 一覧を更新
      const list = loadProjectList();
      const existing = list.find(p => p.id === id);
      let newList;
      if (existing) {
        newList = list.map(p => p.id === id ? { ...p, name: projectName, savedAt } : p);
      } else {
        newList = [{ id, name: projectName, savedAt }, ...list];
      }
      localStorage.setItem(LS_PROJECT_LIST, JSON.stringify(newList));
      setSavedProjects(newList);
      setProjectId(id);
      showToast(`「${projectName}」を保存しました`);
    } catch (e) {
      console.error(e);
      showToast('保存に失敗しました', 'error');
    }
  };

  // 読込
  const loadProject = (id) => {
    try {
      const json = localStorage.getItem(LS_PROJECT_PREFIX + id);
      if (!json) {
        showToast('プロジェクトが見つかりません', 'error');
        return;
      }
      const data = JSON.parse(json);
      loadData(data);
      setProjectId(id);
      setModalType(null);
      showToast(`「${data.projectName}」を読み込みました`);
    } catch (e) {
      console.error(e);
      showToast('読込に失敗しました', 'error');
    }
  };

  // プロジェクト削除
  const deleteProject = (id, name) => {
    if (!confirm(`「${name}」を削除しますか?`)) return;
    try {
      localStorage.removeItem(LS_PROJECT_PREFIX + id);
      const list = loadProjectList().filter(p => p.id !== id);
      localStorage.setItem(LS_PROJECT_LIST, JSON.stringify(list));
      setSavedProjects(list);
      if (projectId === id) setProjectId(null);
      showToast('プロジェクトを削除しました');
    } catch (e) {
      showToast('削除に失敗しました', 'error');
    }
  };

  // 新規プロジェクト
  const newProject = () => {
    if ((edges.length > 0 || ductEdges.length > 0) && !confirm('現在のプロジェクトを破棄して新規作成しますか?')) return;
    setProjectName('新規プロジェクト');
    setProjectId(null);
    setFrames(INITIAL_FRAMES);
    setNodes([]);
    setEdges([]);
    setDuctNodes([]);
    setDuctEdges([]);
    setEquipments([]);
    setSelectedEdgeId(null);
    setSelectedDuctEdgeId(null);
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
    setDrawingFromId(null);
    setDrawingDuctFromId(null);
    setView(INITIAL_VIEW);
    clearHistory(); // 新規プロジェクトなので履歴破棄
    showToast('新規プロジェクトを作成しました');
  };

  // JSON エクスポート
  const exportJson = () => {
    try {
      const data = getCurrentData();
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${projectName || 'project'}.json`;
      a.click();
      URL.revokeObjectURL(url);
      showToast('JSONファイルをダウンロードしました');
    } catch (e) {
      showToast('エクスポートに失敗しました', 'error');
    }
  };

  // JSON インポート
  const importJson = (file) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = JSON.parse(e.target.result);
        loadData(data);
