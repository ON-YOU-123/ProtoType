                      <tr key={`${d.ductType}-${d.size}`}>
                        <td>{d.ductType}</td><td>{d.size}</td>
                        <td className="num">{d.count}</td><td className="num">{Math.round(d.totalLength)} mm</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}

              <div className="summary-section-title">ダクト継手集計</div>
              {summary.ductFittings.length === 0 ? (
                <div style={{fontSize: '11px', color: '#888'}}>ダクト継手はありません</div>
              ) : (
                <table>
                  <thead><tr><th>種類</th><th>サイズ</th><th className="num">個数</th></tr></thead>
                  <tbody>
                    {summary.ductFittings.map(f => (
                      <tr key={`${f.type}-${f.size}`}>
                        <td>{f.type}</td><td>{f.size}</td><td className="num">{f.count}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}

              <div className="summary-section-title">系統別集計(配管)</div>
              {summary.pipeSystems.length === 0 ? (
                <div style={{fontSize: '11px', color: '#888'}}>配管が未配置です</div>
              ) : (
                <table>
                  <thead><tr><th>系統</th><th>内容</th><th className="num">本数</th><th className="num">長さ</th></tr></thead>
                  <tbody>
                    {summary.pipeSystems.map(s => (
                      <tr key={s.system}>
                        <td>{s.system}</td>
                        <td style={{fontSize: '10px'}}>{s.typesText}</td>
                        <td className="num">{s.count}</td>
                        <td className="num">{Math.round(s.totalLength)} mm</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}

              <div className="summary-section-title">系統別集計(ダクト)</div>
              {summary.ductSystems.length === 0 ? (
                <div style={{fontSize: '11px', color: '#888'}}>ダクトが未配置です</div>
              ) : (
                <table>
                  <thead><tr><th>系統</th><th>内容</th><th className="num">本数</th><th className="num">長さ</th></tr></thead>
                  <tbody>
                    {summary.ductSystems.map(s => (
                      <tr key={s.system}>
                        <td>{s.system}</td>
                        <td style={{fontSize: '10px'}}>{s.typesText}</td>
                        <td className="num">{s.count}</td>
                        <td className="num">{Math.round(s.totalLength)} mm</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}

              <div style={{marginTop: 14}}>
                <button
                  className="btn btn-primary"
                  onClick={exportExcel}
                  disabled={edges.length === 0 && ductEdges.length === 0 && equipments.length === 0}
                  style={{width: '100%', padding: '8px', fontSize: '12px', cursor: (edges.length === 0 && ductEdges.length === 0 && equipments.length === 0) ? 'not-allowed' : 'pointer', opacity: (edges.length === 0 && ductEdges.length === 0 && equipments.length === 0) ? 0.5 : 1}}
                >
                  📊 Excel出力
                </button>
                <div style={{fontSize: '10px', color: '#666', marginTop: 6, lineHeight: 1.5}}>
                  プロジェクト情報・配管・ダクト・継手集計・系統別集計・配管詳細・ダクト詳細・干渉一覧・勾配警告・梁スリーブ要・機器一覧の各シートを含む.xlsxファイルを出力します。
                </div>
              </div>
            </React.Fragment>
          )}

          {mode === 'draw' && (
            <React.Fragment>
              <div className="panel-title">凡例</div>
              <div className="legend-box">
                {PIPE_TYPES.map(type => (
                  <div key={type} className="legend-row">
                    <div className="legend-swatch" style={{background: PIPE_COLORS[type]}}></div>
                    <span>{type}{isSlopedPipe(type) ? ' (勾配あり)' : ''}</span>
                  </div>
                ))}
              </div>
              <div className="legend-box">
                <div className="legend-row"><div className="legend-swatch" style={{background: '#2b6cb0', borderRadius: '50%'}}></div><span>エルボ</span></div>
                <div className="legend-row"><div className="legend-swatch" style={{background: '#38a169', borderRadius: '50%'}}></div><span>チーズ</span></div>
                <div className="legend-row"><div className="legend-swatch" style={{background: '#dd6b20'}}></div><span>クロス</span></div>
              </div>
              <div className="legend-box" style={{fontSize: '10px', lineHeight: 1.6}}>
                <b>高さ情報:</b><br/>
                ・配管はFL+◯◯◯のレベルを持つ<br/>
                ・排水・ドレンは勾配で終点が下がる<br/>
                ・干渉判定は平面+高さの論理積<br/><br/>
                <b>保存・読込:</b><br/>
                ・ヘッダーでプロジェクト名編集<br/>
                ・「保存」で記録<br/>
                ・メニューから読込・サンプル選択
              </div>
            </React.Fragment>
          )}

          {mode === 'frame' && (
            <React.Fragment>
              <div className="panel-title">躯体一覧 ({frames.length})</div>
              {frames.map(fr => (
                <div key={fr.id} className="clash-item" style={{borderLeftColor: FRAME_COLORS[fr.type], borderColor: '#ccc', cursor: 'default', background: '#fff'}}>
                  <div style={{fontWeight: 'bold', color: '#444'}}>{fr.name}</div>
                  <div className="clash-item-detail">{fr.w} × {fr.h} mm / FL+{fr.bottomFL}〜+{fr.topFL}</div>
                </div>
              ))}
              {frames.length === 0 && <div style={{fontSize: '11px', color: '#888'}}>躯体は配置されていません</div>}
            </React.Fragment>
          )}

          {mode === 'equipment' && (
            <React.Fragment>
              <div className="panel-title">機器一覧 ({equipments.length})</div>
              {equipments.map(eq => {
                const def = EQUIPMENT_DEFS[eq.equipType];
                return (
                  <div key={eq.id} className="clash-item" style={{borderLeftColor: def ? def.color : '#888', borderColor: '#ccc', cursor: 'default', background: '#fff'}}>
                    <div style={{fontWeight: 'bold', color: '#444'}}>{eq.name}</div>
                    <div className="clash-item-detail">{Math.round(eq.w * SCALE_MM_PER_PX)} × {Math.round(eq.h * SCALE_MM_PER_PX)} mm / FL+{eq.bottomFL}〜+{eq.topFL}</div>
                  </div>
                );
              })}
              {equipments.length === 0 && <div style={{fontSize: '11px', color: '#888'}}>機器は配置されていません</div>}
            </React.Fragment>
          )}
        </div>
      </div>

      <div className="status-bar">
        <span>
          視点: {viewMode === 'iso' ? 'アイソメ' : '平面'}  |  モード: {mode === 'draw' ? '配管描画' : mode === 'duct' ? 'ダクト描画' : mode === 'frame' ? `躯体追加${frameType ? `(${FRAME_LABELS[frameType]})` : ''}` : mode === 'equipment' ? `機器追加${equipmentType ? `(${EQUIPMENT_DEFS[equipmentType].label})` : ''}` : mode === 'select' ? '選択・編集' : mode === 'clash' ? '干渉チェック' : '拾い集計'}
          {mode === 'draw' && `  |  ${currentPipeType} ${currentDiameter} / FL+${currentLevel}${isSlopedPipe(currentPipeType) ? ` / 勾配${slopeRatioToText(SLOPE_DEFAULTS[currentPipeType])}` : ''}`}
          {mode === 'duct' && `  |  ${currentDuctType} ${currentDuctShape === 'round' ? `φ${currentDuctSize.d}` : `${currentDuctSize.w}×${currentDuctSize.h}`} / FL+${currentDuctLevel}`}
        </span>
        <span>
          配管: {edges.length}本 / ダクト: {ductEdges.length}本 / 躯体: {frames.length} / 機器: {equipments.length} / 干渉: {clashes.filter(c => c.clashKind !== 'clearance').length}件 / 離隔: {clashes.filter(c => c.clashKind === 'clearance').length}件 / 警告: {slopeWarnings.length}件 / スリーブ: {sleeveWarnings.length}件  |  倍率: {(zoomLevel * 100).toFixed(0)}%
        </span>
      </div>

      {/* 読込モーダル */}
      {modalType === 'load' && (
        <div className="modal-overlay" onClick={() => setModalType(null)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-title">保存済みプロジェクトから開く</div>
            {savedProjects.length === 0 ? (
              <div style={{padding: 20, textAlign: 'center', color: '#888'}}>保存されたプロジェクトはありません</div>
            ) : (
              savedProjects.map(p => (
                <div key={p.id} className="project-list-row" onClick={() => loadProject(p.id)}>
                  <div className="project-list-info">
                    <div className="project-list-name">{p.name}</div>
                    <div className="project-list-date">最終保存: {new Date(p.savedAt).toLocaleString('ja-JP')}</div>
                  </div>
                  <div className="project-list-actions">
                    <button className="btn btn-danger" onClick={(e) => { e.stopPropagation(); deleteProject(p.id, p.name); }}>削除</button>
                  </div>
                </div>
              ))
            )}
            <div style={{marginTop: 14, textAlign: 'right'}}>
              <button className="btn" onClick={() => setModalType(null)}>閉じる</button>
            </div>
          </div>
        </div>
      )}

      {/* サンプル選択モーダル */}
      {modalType === 'samples' && (
        <div className="modal-overlay" onClick={() => setModalType(null)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-title">サンプルプロジェクトから開く</div>
            <div style={{fontSize: 11, color: '#666', marginBottom: 12}}>
              デモ用に用意したサンプルです。サンプル1とサンプル2を切り替えて、設計レビュー前後の状態の違いを確認できます。
            </div>
            {SAMPLES.map((s, i) => (
              <div key={i} className="sample-card" onClick={() => loadSample(s)}>
                <div className="sample-card-name">{s.name}</div>
                <div className="sample-card-desc">{s.description}</div>
              </div>
            ))}
            <div style={{marginTop: 14, textAlign: 'right'}}>
              <button className="btn" onClick={() => setModalType(null)}>閉じる</button>
            </div>
          </div>
        </div>
      )}
    </React.Fragment>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
