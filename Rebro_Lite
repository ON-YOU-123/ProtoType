          ) : mode === 'equipment' ? (
            <React.Fragment>
              <div className="sidebar-section">
                <div className="sidebar-section-title">機器種別</div>
                {EQUIPMENT_TYPES.map(type => {
                  const def = EQUIPMENT_DEFS[type];
                  return (
                    <div key={type} className={`sidebar-item ${equipmentType === type ? 'active' : ''}`} style={equipmentType === type ? {background: def.color, color: '#fff'} : {}} onClick={() => startEquipmentAdd(type)}>
                      <span style={{display: 'inline-block', width: '12px', height: '8px', background: def.color, marginRight: '6px', verticalAlign: 'middle', border: '1px solid #666'}}></span>
                      {def.label}
                    </div>
