                })}
              </div>
              {equipmentType && (
                <div className="sidebar-section">
                  <div className="sidebar-section-title">選択中: {EQUIPMENT_DEFS[equipmentType].label}</div>
                  <div style={{fontSize: '10px', color: '#666', lineHeight: 1.6}}>
                    サイズ: {EQUIPMENT_DEFS[equipmentType].width * SCALE_MM_PER_PX} × {EQUIPMENT_DEFS[equipmentType].height * SCALE_MM_PER_PX} mm<br/>
                    高さ: FL+{EQUIPMENT_DEFS[equipmentType].bottomFL}〜+{EQUIPMENT_DEFS[equipmentType].topFL}<br/>
                    関連配管: {EQUIPMENT_DEFS[equipmentType].relatedPipes.join('・')}
                  </div>
                </div>
