  // サンプル読込
  const loadSample = (sample) => {
    loadData(sample.data);
    setProjectId(null);
    setModalType(null);
    showToast(`「${sample.name}」を読み込みました`);
  };

  // ===== 派生データの計算(useMemo で効率化) =====

  // 各配管エッジの始点FL・終点FL・長さを計算
  // 勾配のある配管は始点FLから配管長と勾配で終点FLを自動算出
  // 用途: 干渉判定・勾配警告・拾い集計・属性表示
  const edgeLevels = useMemo(() => {
    const map = {};
    edges.forEach(e => {
      const n1 = nodes.find(n => n.id === e.startId);
      const n2 = nodes.find(n => n.id === e.endId);
      if (!n1 || !n2) return;
      const lenMM = distanceMM(n1, n2);  // ピクセル距離を実寸mmに変換
      const startLv = n1.level !== undefined ? n1.level : DEFAULT_PIPE_LEVEL;
      let endLv;
      if (isSlopedPipe(e.pipeType) && e.slopeDivisor) {
        // 排水・ドレンの勾配あり配管は終点FLを自動計算
        endLv = calcEndLevel(startLv, e.slopeDivisor, lenMM);
      } else {
        // 水平配管(終点ノードのレベルがあればそれを採用、なければ始点と同じ)
        endLv = n2.level !== undefined ? n2.level : startLv;
      }
      map[e.id] = { startLv, endLv, length: lenMM };
    });
    return map;
  }, [edges, nodes]);

  // 干渉判定:配管・ダクト・機器・躯体の組み合わせで「平面+高さの両方で重なる」ものを検出
  // 判定の流れ:
  //   1. ペアごとに平面のAABBが重なるかチェック(粗い篩い分け)
  //   2. 高さ範囲も重なるかチェック
  //   3. 両方YESなら干渉
  // 例外:
  //   - 機器の関連配管(室内機と冷温水管など)は接続前提なので干渉扱いしない
  //   - 梁のせいの中に配管が完全内包される場合は干渉ではなく「梁スリーブ」として別判定
  // ----- 離隔考慮の判定 -----
  // 各干渉結果には clashKind を付与:
  //   - 'clash':実干渉(配管・ダクト生サイズで重なる)
  //   - 'clearance':離隔不足(生サイズでは重ならないが、保温厚+施工離隔を加味すると重なる)
  // 設計上、両者は施工性に与える影響が違うので区別して扱う
  const clashes = useMemo(() => {
    const results = [];
    edges.forEach(edge => {
      const n1 = nodes.find(n => n.id === edge.startId);
      const n2 = nodes.find(n => n.id === edge.endId);
      if (!n1 || !n2) return;
      const lvInfo = edgeLevels[edge.id];
      if (!lvInfo) return;
      const pipeRange = pipeHeightRange(lvInfo.startLv, lvInfo.endLv, edge.diameter);
      const segAABB = segmentAABB(n1, n2);
      // 離隔込みの拡張版(離隔不足判定で使用)
      const pipeExtra = pipeExtraMM(edge);
      const pipeRangeExt = pipeHeightRangeExpanded(lvInfo.startLv, lvInfo.endLv, edge.diameter, pipeExtra);
      const segAABBExt = segmentAABB(n1, n2, 8 + pipeExtra * 2 / SCALE_MM_PER_PX);

      frames.forEach(fr => {
        // 拡張版で重ならなければ離隔も含めて重ならない → 検査終了
        if (!aabbIntersect(segAABBExt, fr)) return;
        const frameRange = { low: fr.bottomFL, high: fr.topFL };
        if (!heightOverlap(pipeRangeExt, frameRange)) return;
        // スリーブ判定:配管が梁のせいの中に完全内包 → 干渉ではなくスリーブ警告(離隔判定からも除外)
        if (fr.type === 'beam' && heightFullyContained(pipeRange, frameRange)) return;
        // 実干渉か離隔不足かを判定
        const isRealClash = aabbIntersect(segAABB, fr) && heightOverlap(pipeRange, frameRange);
        results.push({
          id: `${edge.id}-${fr.id}`,
          type: '配管 vs 躯体',
          clashKind: isRealClash ? 'clash' : 'clearance',
          edgeId: edge.id,
          frameId: fr.id,
          description: `${edge.pipeType}${edge.diameter} と ${fr.name}`,
          detail: isRealClash
            ? `配管: FL+${pipeRange.low}〜+${pipeRange.high} / ${fr.name}: FL+${fr.bottomFL}〜+${fr.topFL}`
            : `配管(離隔+${pipeExtra}mm): FL+${pipeRangeExt.low}〜+${pipeRangeExt.high} / ${fr.name}: FL+${fr.bottomFL}〜+${fr.topFL}`,
          x: (Math.max(segAABB.x, fr.x) + Math.min(segAABB.x + segAABB.w, fr.x + fr.w)) / 2,
          y: (Math.max(segAABB.y, fr.y) + Math.min(segAABB.y + segAABB.h, fr.y + fr.h)) / 2,
        });
      });
      // 配管 vs 機器
      equipments.forEach(eq => {
        if (!aabbIntersect(segAABBExt, eq)) return;
        const eqRange = { low: eq.bottomFL, high: eq.topFL };
        if (!heightOverlap(pipeRangeExt, eqRange)) return;
        // 関連配管は接続想定なので干渉扱いしない(設備設計の通例)
        const def = EQUIPMENT_DEFS[eq.equipType];
        if (def && def.relatedPipes.includes(edge.pipeType)) return;
        const isRealClash = aabbIntersect(segAABB, eq) && heightOverlap(pipeRange, eqRange);
        results.push({
          id: `${edge.id}-${eq.id}`,
          type: '配管 vs 機器',
          clashKind: isRealClash ? 'clash' : 'clearance',
          edgeId: edge.id,
          equipmentId: eq.id,
          description: `${edge.pipeType}${edge.diameter} と ${eq.name}`,
          detail: isRealClash
            ? `配管: FL+${pipeRange.low}〜+${pipeRange.high} / ${eq.name}: FL+${eq.bottomFL}〜+${eq.topFL}`
            : `配管(離隔+${pipeExtra}mm): FL+${pipeRangeExt.low}〜+${pipeRangeExt.high} / ${eq.name}: FL+${eq.bottomFL}〜+${eq.topFL}`,
          x: (Math.max(segAABB.x, eq.x) + Math.min(segAABB.x + segAABB.w, eq.x + eq.w)) / 2,
          y: (Math.max(segAABB.y, eq.y) + Math.min(segAABB.y + segAABB.h, eq.y + eq.h)) / 2,
        });
      });
    });
    // 配管 vs 配管(他系統)
    for (let i = 0; i < edges.length; i++) {
      for (let j = i + 1; j < edges.length; j++) {
        const e1 = edges[i], e2 = edges[j];
        if (e1.pipeType === e2.pipeType) continue;
        if (e1.startId === e2.startId || e1.startId === e2.endId ||
            e1.endId === e2.startId || e1.endId === e2.endId) continue;
        const n1a = nodes.find(n => n.id === e1.startId);
        const n1b = nodes.find(n => n.id === e1.endId);
        const n2a = nodes.find(n => n.id === e2.startId);
        const n2b = nodes.find(n => n.id === e2.endId);
        if (!n1a || !n1b || !n2a || !n2b) continue;
        const lv1 = edgeLevels[e1.id], lv2 = edgeLevels[e2.id];
        if (!lv1 || !lv2) continue;
        const aabb1 = segmentAABB(n1a, n1b);
        const aabb2 = segmentAABB(n2a, n2b);
        const range1 = pipeHeightRange(lv1.startLv, lv1.endLv, e1.diameter);
        const range2 = pipeHeightRange(lv2.startLv, lv2.endLv, e2.diameter);
        // 離隔込み(両方の保温+施工離隔の和を考慮)
        const extra1 = pipeExtraMM(e1);
        const extra2 = pipeExtraMM(e2);
        const aabb1Ext = segmentAABB(n1a, n1b, 8 + extra1 * 2 / SCALE_MM_PER_PX);
        const aabb2Ext = segmentAABB(n2a, n2b, 8 + extra2 * 2 / SCALE_MM_PER_PX);
        const range1Ext = pipeHeightRangeExpanded(lv1.startLv, lv1.endLv, e1.diameter, extra1);
        const range2Ext = pipeHeightRangeExpanded(lv2.startLv, lv2.endLv, e2.diameter, extra2);
        if (!aabbIntersect(aabb1Ext, aabb2Ext)) continue;
        if (!heightOverlap(range1Ext, range2Ext)) continue;
        const isRealClash = aabbIntersect(aabb1, aabb2) && heightOverlap(range1, range2);
        results.push({
          id: `${e1.id}-${e2.id}`,
          type: '配管 vs 配管',
          clashKind: isRealClash ? 'clash' : 'clearance',
          edgeId: e1.id,
          edgeId2: e2.id,
          description: `${e1.pipeType}${e1.diameter} と ${e2.pipeType}${e2.diameter}`,
          detail: isRealClash
            ? `${e1.pipeType}: FL+${range1.low}〜+${range1.high} / ${e2.pipeType}: FL+${range2.low}〜+${range2.high}`
            : `${e1.pipeType}(離隔+${extra1}mm) と ${e2.pipeType}(離隔+${extra2}mm)が離隔不足`,
          x: (Math.max(aabb1.x, aabb2.x) + Math.min(aabb1.x + aabb1.w, aabb2.x + aabb2.w)) / 2,
          y: (Math.max(aabb1.y, aabb2.y) + Math.min(aabb1.y + aabb1.h, aabb2.y + aabb2.h)) / 2,
        });
      }
    }

    // === ダクト関連の干渉判定 ===
    // ダクト vs 躯体、ダクト vs 機器、ダクト vs 配管
    ductEdges.forEach(de => {
      const dn1 = ductNodes.find(n => n.id === de.startId);
      const dn2 = ductNodes.find(n => n.id === de.endId);
      if (!dn1 || !dn2) return;
      const dAABB = ductAABB(dn1, dn2, de.shape, de.size);
      const dRange = ductHeightRange(de.level, de.shape, de.size);

      // ダクト vs 躯体
      frames.forEach(fr => {
        if (!aabbIntersect(dAABB, fr)) return;
        const frameRange = { low: fr.bottomFL, high: fr.topFL };
        if (!heightOverlap(dRange, frameRange)) return;
        // 梁にダクトが完全内包される場合はスリーブで対応可能
        if (fr.type === 'beam' && heightFullyContained(dRange, frameRange)) return;
        const sizeLabel = de.shape === 'round' ? `φ${de.size.d}` : `${de.size.w}×${de.size.h}`;
        results.push({
          id: `${de.id}-${fr.id}`,
          type: 'ダクト vs 躯体',
          clashKind: 'clash',
          ductEdgeId: de.id,
          frameId: fr.id,
          description: `${de.ductType} ${sizeLabel} と ${fr.name}`,
          detail: `ダクト: FL+${dRange.low}〜+${dRange.high} / ${fr.name}: FL+${fr.bottomFL}〜+${fr.topFL}`,
          x: (Math.max(dAABB.x, fr.x) + Math.min(dAABB.x + dAABB.w, fr.x + fr.w)) / 2,
          y: (Math.max(dAABB.y, fr.y) + Math.min(dAABB.y + dAABB.h, fr.y + fr.h)) / 2,
        });
      });

      // ダクト vs 機器
      equipments.forEach(eq => {
        if (!aabbIntersect(dAABB, eq)) return;
        const eqRange = { low: eq.bottomFL, high: eq.topFL };
        if (!heightOverlap(dRange, eqRange)) return;
        const sizeLabel = de.shape === 'round' ? `φ${de.size.d}` : `${de.size.w}×${de.size.h}`;
        results.push({
          id: `${de.id}-${eq.id}`,
          type: 'ダクト vs 機器',
          clashKind: 'clash',
          ductEdgeId: de.id,
          equipmentId: eq.id,
          description: `${de.ductType} ${sizeLabel} と ${eq.name}`,
          detail: `ダクト: FL+${dRange.low}〜+${dRange.high} / ${eq.name}: FL+${eq.bottomFL}〜+${eq.topFL}`,
          x: (Math.max(dAABB.x, eq.x) + Math.min(dAABB.x + dAABB.w, eq.x + eq.w)) / 2,
          y: (Math.max(dAABB.y, eq.y) + Math.min(dAABB.y + dAABB.h, eq.y + eq.h)) / 2,
        });
      });

      // ダクト vs 配管(全管種)
      edges.forEach(edge => {
        const n1 = nodes.find(n => n.id === edge.startId);
        const n2 = nodes.find(n => n.id === edge.endId);
        if (!n1 || !n2) return;
        const lvInfo = edgeLevels[edge.id];
        if (!lvInfo) return;
        const pAABB = segmentAABB(n1, n2);
        const pRange = pipeHeightRange(lvInfo.startLv, lvInfo.endLv, edge.diameter);
        if (!aabbIntersect(dAABB, pAABB)) return;
        if (!heightOverlap(dRange, pRange)) return;
        const sizeLabel = de.shape === 'round' ? `φ${de.size.d}` : `${de.size.w}×${de.size.h}`;
        results.push({
          id: `${de.id}-${edge.id}`,
          type: 'ダクト vs 配管',
          clashKind: 'clash',
          ductEdgeId: de.id,
          edgeId: edge.id,
          description: `${de.ductType}${sizeLabel} と ${edge.pipeType}${edge.diameter}`,
          detail: `ダクト: FL+${dRange.low}〜+${dRange.high} / 配管: FL+${pRange.low}〜+${pRange.high}`,
          x: (Math.max(dAABB.x, pAABB.x) + Math.min(dAABB.x + dAABB.w, pAABB.x + pAABB.w)) / 2,
          y: (Math.max(dAABB.y, pAABB.y) + Math.min(dAABB.y + dAABB.h, pAABB.y + pAABB.h)) / 2,
        });
      });
    });

    // ダクト vs ダクト(異種別のみ)
    for (let i = 0; i < ductEdges.length; i++) {
      for (let j = i + 1; j < ductEdges.length; j++) {
        const d1 = ductEdges[i], d2 = ductEdges[j];
        if (d1.ductType === d2.ductType) continue;
        if (d1.startId === d2.startId || d1.startId === d2.endId ||
            d1.endId === d2.startId || d1.endId === d2.endId) continue;
        const d1a = ductNodes.find(n => n.id === d1.startId);
        const d1b = ductNodes.find(n => n.id === d1.endId);
        const d2a = ductNodes.find(n => n.id === d2.startId);
        const d2b = ductNodes.find(n => n.id === d2.endId);
        if (!d1a || !d1b || !d2a || !d2b) continue;
        const aabb1 = ductAABB(d1a, d1b, d1.shape, d1.size);
        const aabb2 = ductAABB(d2a, d2b, d2.shape, d2.size);
        if (!aabbIntersect(aabb1, aabb2)) continue;
        const r1 = ductHeightRange(d1.level, d1.shape, d1.size);
        const r2 = ductHeightRange(d2.level, d2.shape, d2.size);
        if (!heightOverlap(r1, r2)) continue;
        const s1 = d1.shape === 'round' ? `φ${d1.size.d}` : `${d1.size.w}×${d1.size.h}`;
        const s2 = d2.shape === 'round' ? `φ${d2.size.d}` : `${d2.size.w}×${d2.size.h}`;
        results.push({
          id: `${d1.id}-${d2.id}`,
          type: 'ダクト vs ダクト',
          clashKind: 'clash',
          ductEdgeId: d1.id,
          ductEdgeId2: d2.id,
          description: `${d1.ductType}${s1} と ${d2.ductType}${s2}`,
          detail: `${d1.ductType}: FL+${r1.low}〜+${r1.high} / ${d2.ductType}: FL+${r2.low}〜+${r2.high}`,
          x: (Math.max(aabb1.x, aabb2.x) + Math.min(aabb1.x + aabb1.w, aabb2.x + aabb2.w)) / 2,
          y: (Math.max(aabb1.y, aabb2.y) + Math.min(aabb1.y + aabb1.h, aabb2.y + aabb2.h)) / 2,
        });
      }
    }

    return results;
  }, [edges, nodes, frames, equipments, edgeLevels, ductEdges, ductNodes]);

  const clashedEdgeIds = useMemo(() => {
    const set = new Set();
    clashes.forEach(c => {
      if (c.edgeId) set.add(c.edgeId);
      if (c.edgeId2) set.add(c.edgeId2);
    });
    return set;
  }, [clashes]);

  const clashedDuctEdgeIds = useMemo(() => {
    const set = new Set();
    clashes.forEach(c => {
      if (c.ductEdgeId) set.add(c.ductEdgeId);
      if (c.ductEdgeId2) set.add(c.ductEdgeId2);
    });
    return set;
  }, [clashes]);

  // 勾配警告:排水・ドレン配管の流下方向に問題がないかチェック
  // - 逆勾配:流下方向に上がっている(計算誤りまたは設計ミス)
  // - 勾配未設定:勾配が0で水平(排水・ドレンとして機能しない)
  const slopeWarnings = useMemo(() => {
    const warnings = [];
    edges.forEach(e => {
      if (!isSlopedPipe(e.pipeType)) return; // 勾配が必要なのは排水・ドレンのみ
      const lv = edgeLevels[e.id];
      if (!lv) return;
      const drop = lv.startLv - lv.endLv; // 始点FL - 終点FL(正なら下り勾配)
      if (drop < 0) {
        warnings.push({
          id: `slope-rev-${e.id}`,
          edgeId: e.id,
          type: '逆勾配',
          description: `${e.pipeType} ${e.diameter}: 始点 FL+${lv.startLv} → 終点 FL+${lv.endLv} は流下方向に上がっています`,
        });
      }
      if (drop === 0 && !e.slopeDivisor) {
        warnings.push({
          id: `slope-zero-${e.id}`,
          edgeId: e.id,
          type: '勾配未設定',
          description: `${e.pipeType} ${e.diameter}: 勾配が設定されていません`,
        });
      }
    });
    return warnings;
  }, [edges, edgeLevels]);

  // 梁スリーブ警告:配管・ダクトが梁を貫通する設計判断を促す警告
  // 条件:
  //   1. 配管/ダクトが梁と平面で重なる(横断する)
  //   2. 配管/ダクトの高さ範囲が梁のせいの中に完全内包される
  //   3. 進行方向が梁の長辺方向と直交している(平行に走るのではなく横切る)
  // この条件を満たす配置は「スリーブを通せば施工可能」だが、設計時に必ず認識すべき項目
  // 実装メモ:このパターンは clashes の判定からは除外される(完全内包は干渉ではない)
  const sleeveWarnings = useMemo(() => {
    const warnings = [];

    // 配管の判定
    edges.forEach(edge => {
      const n1 = nodes.find(n => n.id === edge.startId);
      const n2 = nodes.find(n => n.id === edge.endId);
      if (!n1 || !n2) return;
      const lvInfo = edgeLevels[edge.id];
      if (!lvInfo) return;
      const pipeRange = pipeHeightRange(lvInfo.startLv, lvInfo.endLv, edge.diameter);
      const segAABB = segmentAABB(n1, n2);
      const pipeDx = Math.abs(n2.x - n1.x);
      const pipeDy = Math.abs(n2.y - n1.y);
      const pipeIsHorizontal = pipeDx >= pipeDy;

      frames.forEach(fr => {
        if (fr.type !== 'beam') return;
        if (!aabbIntersect(segAABB, fr)) return;
        const frameRange = { low: fr.bottomFL, high: fr.topFL };
        // 完全内包(配管が梁のせいの中に完全に収まる)
        if (!heightFullyContained(pipeRange, frameRange)) return;
        // 進行方向が梁の長辺と直交している
        const beamIsHorizontal = fr.w >= fr.h;
        if (pipeIsHorizontal === beamIsHorizontal) return;
        warnings.push({
          id: `sleeve-pipe-${edge.id}-${fr.id}`,
          edgeId: edge.id,
          frameId: fr.id,
          type: '梁スリーブ',
          description: `${edge.pipeType}${edge.diameter} が ${fr.name} を貫通`,
        });
      });
    });

    // ダクトの判定
    ductEdges.forEach(de => {
      const dn1 = ductNodes.find(n => n.id === de.startId);
      const dn2 = ductNodes.find(n => n.id === de.endId);
      if (!dn1 || !dn2) return;
      const dAABB = ductAABB(dn1, dn2, de.shape, de.size);
      const dRange = ductHeightRange(de.level, de.shape, de.size);
      const ductDx = Math.abs(dn2.x - dn1.x);
      const ductDy = Math.abs(dn2.y - dn1.y);
      const ductIsHorizontal = ductDx >= ductDy;

      frames.forEach(fr => {
        if (fr.type !== 'beam') return;
        if (!aabbIntersect(dAABB, fr)) return;
        const frameRange = { low: fr.bottomFL, high: fr.topFL };
        if (!heightFullyContained(dRange, frameRange)) return;
        const beamIsHorizontal = fr.w >= fr.h;
        if (ductIsHorizontal === beamIsHorizontal) return;
        const sizeLabel = de.shape === 'round' ? `φ${de.size.d}` : `${de.size.w}×${de.size.h}`;
        warnings.push({
          id: `sleeve-duct-${de.id}-${fr.id}`,
          ductEdgeId: de.id,
          frameId: fr.id,
          type: '梁スリーブ',
          description: `${de.ductType}${sizeLabel} が ${fr.name} を貫通`,
        });
      });
    });

    return warnings;
  }, [edges, nodes, frames, edgeLevels, ductEdges, ductNodes]);

  // 配管の継手判定:各ノードに接続するエッジの数と角度から継手種類を動的に決定
  // ノード自体に継手種類を持たせず、グラフ構造から都度算出することで、
  // 配管の追加・削除・変更時の整合性管理を不要にしている
  //
  // 判定ルール:
  //   接続エッジ数 1 → 'end'(端点、口を開けたままの配管)
  //   接続エッジ数 2 → 角度をチェック
  //     - 直角に近い(内積/絶対値の比 < 0.3、約72度以上の折れ角)→ 'elbow'(エルボ)
  //     - ほぼ一直線 → 'joint'(継手不要、内部的にカウント)
  //   接続エッジ数 3 → 'tee'(チーズ、T字分岐)
  //   接続エッジ数 4 以上 → 'cross'(クロス、十字分岐)
  //   接続エッジ数 0 → 'isolated'(孤立、描画中に発生し得る一時状態)
  const nodeFittingTypes = useMemo(() => {
    const map = {};
    nodes.forEach(n => {
      const connected = edges.filter(e => e.startId === n.id || e.endId === n.id);
      if (connected.length === 1) map[n.id] = 'end';
      else if (connected.length === 2) {
        // 2本接続:角度を見てエルボか直線継ぎかを判定
        const others = connected.map(e => {
          const otherId = e.startId === n.id ? e.endId : e.startId;
          return nodes.find(no => no.id === otherId);
        }).filter(Boolean);
        if (others.length === 2) {
          // n から両側のノードへのベクトルを計算
          const dx1 = others[0].x - n.x, dy1 = others[0].y - n.y;
          const dx2 = others[1].x - n.x, dy2 = others[1].y - n.y;
          // ベクトルの内積/積の絶対値で角度を判定(cosθ の絶対値)
          const dot = (dx1 * dx2 + dy1 * dy2);
          const mag = Math.sqrt(dx1*dx1+dy1*dy1) * Math.sqrt(dx2*dx2+dy2*dy2);
          // |cosθ| < 0.3 なら直角に近い(エルボ)
          if (mag > 0 && Math.abs(dot / mag) < 0.3) map[n.id] = 'elbow';
          else map[n.id] = 'joint';
        }
      } else if (connected.length === 3) map[n.id] = 'tee';
      else if (connected.length >= 4) map[n.id] = 'cross';
      else map[n.id] = 'isolated';
    });
    return map;
  }, [nodes, edges]);

  // ダクトの継手判定(配管と同じロジック、対象が ductNodes/ductEdges になるだけ)
  const ductNodeFittingTypes = useMemo(() => {
    const map = {};
    ductNodes.forEach(n => {
      const connected = ductEdges.filter(e => e.startId === n.id || e.endId === n.id);
      if (connected.length === 1) map[n.id] = 'end';
      else if (connected.length === 2) {
        const others = connected.map(e => {
          const otherId = e.startId === n.id ? e.endId : e.startId;
          return ductNodes.find(no => no.id === otherId);
        }).filter(Boolean);
        if (others.length === 2) {
          const dx1 = others[0].x - n.x, dy1 = others[0].y - n.y;
          const dx2 = others[1].x - n.x, dy2 = others[1].y - n.y;
          const dot = (dx1 * dx2 + dy1 * dy2);
          const mag = Math.sqrt(dx1*dx1+dy1*dy1) * Math.sqrt(dx2*dx2+dy2*dy2);
          if (mag > 0 && Math.abs(dot / mag) < 0.3) map[n.id] = 'elbow';
          else map[n.id] = 'joint';
        }
      } else if (connected.length === 3) map[n.id] = 'tee';
      else if (connected.length >= 4) map[n.id] = 'cross';
      else map[n.id] = 'isolated';
    });
    return map;
  }, [ductNodes, ductEdges]);

  // ===== ズーム/パン =====
  const handleWheel = useCallback((e) => {
    e.preventDefault();
    const world = screenToWorld(e, svgRef, view);
    const factor = e.deltaY < 0 ? 0.85 : 1 / 0.85;
    const newW = view.w * factor;
    const newH = view.h * factor;
    const newZoom = INITIAL_VIEW.w / newW;
    if (newZoom < MIN_ZOOM || newZoom > MAX_ZOOM) return;
    const rect = svgRef.current.getBoundingClientRect();
    const sx = (e.clientX - rect.left) / rect.width;
    const sy = (e.clientY - rect.top) / rect.height;
    setView({ x: world.x - sx * newW, y: world.y - sy * newH, w: newW, h: newH });
  }, [view]);

  const resetView = () => setView(INITIAL_VIEW);

  const zoomIn = () => {
    const newW = view.w * 0.7;
    const newH = view.h * 0.7;
    if (INITIAL_VIEW.w / newW > MAX_ZOOM) return;
    setView({
      x: view.x + (view.w - newW) / 2,
      y: view.y + (view.h - newH) / 2,
      w: newW, h: newH,
    });
  };

  const zoomOut = () => {
    const newW = view.w / 0.7;
    const newH = view.h / 0.7;
    if (INITIAL_VIEW.w / newW < MIN_ZOOM) return;
    setView({
      x: view.x + (view.w - newW) / 2,
      y: view.y + (view.h - newH) / 2,
      w: newW, h: newH,
    });
  };

  const handleSvgMouseDown = useCallback((e) => {
    if (e.shiftKey || e.button === 1) {
      e.preventDefault();
      setIsPanning(true);
      setPanStart({ clientX: e.clientX, clientY: e.clientY, view: { ...view } });
    }
  }, [view]);

  const handleSvgMouseUp = useCallback(() => {
    if (isPanning) {
      setIsPanning(false);
      setPanStart(null);
    }
  }, [isPanning]);

  const handleSvgClick = useCallback((e) => {
    if (isPanning) return;
    if (e.shiftKey) return;

    const world = screenToWorld(e, svgRef, view);

    if (mode === 'frame' && frameType) {
      const x = snapToGrid(world.x);
      const y = snapToGrid(world.y);
      if (!frameStart) {
        setFrameStart({ x, y });
      } else {
        const minX = Math.min(frameStart.x, x);
        const minY = Math.min(frameStart.y, y);
        const w = Math.abs(x - frameStart.x);
        const h = Math.abs(y - frameStart.y);
        if (w >= 20 && h >= 20) {
          const existing = frames.filter(f => f.type === frameType);
          const prefix = frameType === 'beam' ? 'GR-' : 'C-';
          const newName = `${FRAME_LABELS[frameType]} ${prefix}${existing.length + 1}`;
          const newFrame = frameType === 'beam'
            ? { id: `f${Date.now()}`, type: frameType, name: newName, x: minX, y: minY, w, h, bottomFL: 2300, topFL: 2800 }
            : { id: `f${Date.now()}`, type: frameType, name: newName, x: minX, y: minY, w, h, bottomFL: 0, topFL: FLOOR_CONFIG.floorHeight };
          pushHistory();
          setFrames(prev => [...prev, newFrame]);
        }
        setFrameStart(null);
      }
      return;
    }

    // 機器配置モード
    if (mode === 'equipment' && equipmentType) {
      const def = EQUIPMENT_DEFS[equipmentType];
      if (!def) return;
      const cx = snapToGrid(world.x);
      const cy = snapToGrid(world.y);
      // クリック位置を中心に矩形配置
      const x = cx - def.width / 2;
      const y = cy - def.height / 2;
      const existing = equipments.filter(eq => eq.equipType === equipmentType);
      const newName = `${def.label}-${existing.length + 1}`;
      pushHistory();
      setEquipments(prev => [...prev, {
        id: `eq${Date.now()}`,
        equipType: equipmentType,
        name: newName,
        x, y,
        w: def.width,
        h: def.height,
        bottomFL: def.bottomFL,
        topFL: def.topFL,
      }]);
      return;
    }

    // ダクト描画モード
    if (mode === 'duct') {
      let x = snapToGrid(world.x);
      let y = snapToGrid(world.y);
      const NEAR = 15;
      // 異種ダクトのスナップ抑制:
      // 近傍ノードが現在描画中のダクト種別と同じエッジで使われていない場合はスナップしない
      const isDuctNodeCompatible = (nodeId) => {
        const connected = ductEdges.filter(ed => ed.startId === nodeId || ed.endId === nodeId);
        if (connected.length === 0) return true;
        return connected.some(ed => ed.ductType === currentDuctType);
      };
      const nearNode = ductNodes.find(n => distance(n, { x, y }) < NEAR && isDuctNodeCompatible(n.id));
      if (drawingDuctFromId === null) {
        if (nearNode) {
          setDrawingDuctFromId(nearNode.id);
        } else {
          // 起点ノードを新規作成
          pushHistory();
          const newNode = { id: `dn${Date.now()}`, x, y };
          setDuctNodes(prev => [...prev, newNode]);
          setDrawingDuctFromId(newNode.id);
        }
      } else {
        const fromNode = ductNodes.find(n => n.id === drawingDuctFromId);
        if (fromNode) {
          const ortho = orthogonalize(fromNode, { x, y });
          x = ortho.x;
          y = ortho.y;
        }
        if (fromNode && fromNode.x === x && fromNode.y === y) return;
        let targetNodeId;
        // 終点側のスナップにも同じダクト種別チェックを適用
        const targetNear = ductNodes.find(n => distance(n, { x, y }) < NEAR && n.id !== drawingDuctFromId && isDuctNodeCompatible(n.id));
        // ここからエッジ1本(と必要なら終点ノード)を追加 → 1 undo の単位
        pushHistory();
        if (targetNear) {
          targetNodeId = targetNear.id;
        } else {
          const newNode = { id: `dn${Date.now()}`, x, y };
          setDuctNodes(prev => [...prev, newNode]);
          targetNodeId = newNode.id;
        }
        const sizeCopy = currentDuctShape === 'round' ? { d: currentDuctSize.d } : { w: currentDuctSize.w, h: currentDuctSize.h };
        const newEdge = {
          id: `de${Date.now()}`,
          startId: drawingDuctFromId,
          endId: targetNodeId,
          ductType: currentDuctType,
          shape: currentDuctShape,
          size: sizeCopy,
          level: currentDuctLevel,
          system: `${currentDuctType[0]}-1`,
        };
        setDuctEdges(prev => [...prev, newEdge]);
        setDrawingDuctFromId(targetNodeId);
      }
      return;
    }

    if (mode !== 'draw') {
      if (mode === 'select') {
        setSelectedEdgeId(null);
        setSelectedDuctEdgeId(null);
        setSelectedFrameId(null);
        setSelectedEquipmentId(null);
      }
      return;
    }

    let x = snapToGrid(world.x);
    let y = snapToGrid(world.y);

    const NEAR = 15;
    // 異種管のスナップ抑制:
    // 近傍にノードがあっても、そのノードが現在描画中の管種と同じエッジで使われていない場合は
    // スナップしない(新規ノードを作る)。
    // ノードに接続する全エッジを調べ、currentPipeType と同じものが1つでもあればスナップOK。
    const isNodeCompatible = (nodeId) => {
      const connected = edges.filter(ed => ed.startId === nodeId || ed.endId === nodeId);
      if (connected.length === 0) return true; // 孤立ノード(描画途中など)は許容
      return connected.some(ed => ed.pipeType === currentPipeType);
    };
    const nearNode = nodes.find(n => distance(n, { x, y }) < NEAR && isNodeCompatible(n.id));

    if (drawingFromId === null) {
      if (nearNode) {
        setDrawingFromId(nearNode.id);
      } else {
        // 起点を新規ノードとして配置(ここではエッジは追加されないが、ノード追加は記録)
        pushHistory();
        const newNode = { id: `n${Date.now()}`, x, y, level: currentLevel };
        setNodes(prev => [...prev, newNode]);
        setDrawingFromId(newNode.id);
      }
    } else {
      const fromNode = nodes.find(n => n.id === drawingFromId);
      if (fromNode) {
        const ortho = orthogonalize(fromNode, { x, y });
        x = ortho.x;
        y = ortho.y;
      }
      if (fromNode && fromNode.x === x && fromNode.y === y) return;

      let endLevel;
      if (isSlopedPipe(currentPipeType)) {
        const lenMM = distanceMM(fromNode, { x, y });
        const slopeDiv = SLOPE_DEFAULTS[currentPipeType] || 50;
        endLevel = calcEndLevel(fromNode.level || currentLevel, slopeDiv, lenMM);
      } else {
        endLevel = fromNode.level || currentLevel;
      }

      let targetNodeId;
      // 終点側のスナップにも同じ管種チェックを適用
      const targetNear = nodes.find(n => distance(n, { x, y }) < NEAR && n.id !== drawingFromId && isNodeCompatible(n.id));
      // ここからエッジ1本(と必要なら終点ノード)を追加する → 1 undo の単位
      pushHistory();
      if (targetNear) {
        targetNodeId = targetNear.id;
      } else {
        const newNode = { id: `n${Date.now()}`, x, y, level: endLevel };
        setNodes(prev => [...prev, newNode]);
        targetNodeId = newNode.id;
      }

      const newEdge = {
        id: `e${Date.now()}`,
        startId: drawingFromId,
        endId: targetNodeId,
        pipeType: currentPipeType,
        diameter: currentDiameter,
        system: `${currentPipeType[0]}-1`,
        slopeDivisor: isSlopedPipe(currentPipeType) ? (SLOPE_DEFAULTS[currentPipeType] || 50) : null,
      };
      setEdges(prev => [...prev, newEdge]);
      setDrawingFromId(targetNodeId);
    }
  }, [mode, drawingFromId, nodes, currentPipeType, currentDiameter, currentLevel, view, isPanning, frameType, frameStart, frames, equipmentType, equipments, drawingDuctFromId, ductNodes, currentDuctType, currentDuctShape, currentDuctSize, currentDuctLevel]);

  const handleMouseMove = useCallback((e) => {
    if (isPanning && panStart) {
      const rect = svgRef.current.getBoundingClientRect();
      const dx = (e.clientX - panStart.clientX) / rect.width * panStart.view.w;
      const dy = (e.clientY - panStart.clientY) / rect.height * panStart.view.h;
      setView({
        x: panStart.view.x - dx,
        y: panStart.view.y - dy,
        w: panStart.view.w,
        h: panStart.view.h,
      });
      return;
    }
    const world = screenToWorld(e, svgRef, view);
    if (mode === 'frame' && frameType && frameStart) {
      setMousePos({ x: snapToGrid(world.x), y: snapToGrid(world.y) });
      return;
    }
    if (mode === 'equipment' && equipmentType) {
      setMousePos({ x: snapToGrid(world.x), y: snapToGrid(world.y) });
      return;
    }
    // ダクト描画モード
    if (mode === 'duct' && drawingDuctFromId !== null) {
      const fromNode = ductNodes.find(n => n.id === drawingDuctFromId);
      if (!fromNode) {
        setMousePos(null);
        return;
      }
      let x = snapToGrid(world.x);
      let y = snapToGrid(world.y);
      const ortho = orthogonalize(fromNode, { x, y });
      setMousePos(ortho);
      return;
    }
    if (mode !== 'draw' || drawingFromId === null) {
      setMousePos(null);
      return;
    }
    const fromNode = nodes.find(n => n.id === drawingFromId);
    if (!fromNode) return;
    let x = snapToGrid(world.x);
    let y = snapToGrid(world.y);
    const ortho = orthogonalize(fromNode, { x, y });
    setMousePos(ortho);
  }, [mode, drawingFromId, nodes, view, isPanning, panStart, frameType, frameStart, equipmentType, drawingDuctFromId, ductNodes]);

  const handleContextMenu = useCallback((e) => {
    e.preventDefault();
    setDrawingFromId(null);
    setDrawingDuctFromId(null);
    setFrameStart(null);
    setMousePos(null);
  }, []);

  useEffect(() => {
    const onKey = (e) => {
      if (e.key === 'Escape') {
        setDrawingFromId(null);
        setDrawingDuctFromId(null);
        setFrameStart(null);
        setMousePos(null);
        setSelectedEdgeId(null);
        setSelectedDuctEdgeId(null);
        setSelectedFrameId(null);
        setSelectedEquipmentId(null);
        setMenuOpen(false);
        setModalType(null);
      }
      // Ctrl+Z(Macは Cmd+Z)で undo
      // input/textarea にフォーカスがあるときは undo を発火しない(入力欄の操作を優先)
      if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
        const tag = (document.activeElement && document.activeElement.tagName) || '';
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        e.preventDefault();
        undo();
      }
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [history, nodes, edges, ductNodes, ductEdges, frames, equipments, projectName]);

  useEffect(() => {
    const svg = svgRef.current;
    if (!svg) return;
    const wheelHandler = (e) => handleWheel(e);
    svg.addEventListener('wheel', wheelHandler, { passive: false });
    return () => svg.removeEventListener('wheel', wheelHandler);
  }, [handleWheel]);

  // メニュー外クリックで閉じる
  useEffect(() => {
    if (!menuOpen) return;
    const onClick = (e) => {
      if (!e.target.closest('.menu-wrap')) setMenuOpen(false);
    };
    setTimeout(() => document.addEventListener('click', onClick), 0);
    return () => document.removeEventListener('click', onClick);
  }, [menuOpen]);

  const changeMode = (newMode) => {
    setMode(newMode);
    setDrawingFromId(null);
    setDrawingDuctFromId(null);
    setFrameStart(null);
    setFrameType(null);
    setEquipmentType(null);
    setMousePos(null);
    setHighlightedPipeSystem(null);
    setHighlightedDuctSystem(null);
    if (newMode !== 'select') {
      setSelectedEdgeId(null);
      setSelectedDuctEdgeId(null);
      setSelectedFrameId(null);
      setSelectedEquipmentId(null);
    }
  };

  const startFrameAdd = (type) => {
    setMode('frame');
    setFrameType(type);
    setEquipmentType(null);
    setFrameStart(null);
    setDrawingFromId(null);
    setSelectedEdgeId(null);
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
  };

  const startEquipmentAdd = (type) => {
    setMode('equipment');
    setEquipmentType(type);
    setFrameType(null);
    setFrameStart(null);
    setDrawingFromId(null);
    setSelectedEdgeId(null);
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
  };

  const handleEdgeClick = (edgeId, e) => {
    e.stopPropagation();
    if (mode === 'select') {
      setSelectedEdgeId(edgeId);
      setSelectedDuctEdgeId(null);
      setSelectedFrameId(null);
      setSelectedEquipmentId(null);
    }
  };

  const handleDuctEdgeClick = (ductEdgeId, e) => {
    e.stopPropagation();
    if (mode === 'select') {
      setSelectedDuctEdgeId(ductEdgeId);
      setSelectedEdgeId(null);
      setSelectedFrameId(null);
      setSelectedEquipmentId(null);
    }
  };

  const handleFrameClick = (frameId, e) => {
    e.stopPropagation();
    if (mode === 'select') {
      setSelectedFrameId(frameId);
      setSelectedEdgeId(null);
      setSelectedEquipmentId(null);
    }
  };

  const handleEquipmentClick = (equipmentId, e) => {
    e.stopPropagation();
    if (mode === 'select') {
      setSelectedEquipmentId(equipmentId);
      setSelectedEdgeId(null);
      setSelectedFrameId(null);
    }
  };

  const handleClashClick = (clash) => {
    setMode('select');
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
    // 配管 vs *
    if (clash.edgeId && !clash.ductEdgeId) {
      setSelectedEdgeId(clash.edgeId);
      setSelectedDuctEdgeId(null);
      return;
    }
    // ダクト vs * (配管含む):ダクト側を選択優先
    if (clash.ductEdgeId) {
      setSelectedDuctEdgeId(clash.ductEdgeId);
      setSelectedEdgeId(null);
      return;
    }
  };

  const handleWarnClick = (w) => {
    setMode('select');
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
    if (w.edgeId) {
      setSelectedEdgeId(w.edgeId);
      setSelectedDuctEdgeId(null);
    } else if (w.ductEdgeId) {
      setSelectedDuctEdgeId(w.ductEdgeId);
      setSelectedEdgeId(null);
    }
  };

  const handleSleeveClick = (w) => {
    setMode('select');
    setSelectedFrameId(null);
    setSelectedEquipmentId(null);
    if (w.edgeId) {
      setSelectedEdgeId(w.edgeId);
      setSelectedDuctEdgeId(null);
    } else if (w.ductEdgeId) {
      setSelectedDuctEdgeId(w.ductEdgeId);
      setSelectedEdgeId(null);
    }
  };

  const updateSelectedEdge = (updates) => {
    pushHistory();
    setEdges(prev => prev.map(e => e.id === selectedEdgeId ? { ...e, ...updates } : e));
  };

  const updateSelectedDuctEdge = (updates) => {
    pushHistory();
    setDuctEdges(prev => prev.map(e => e.id === selectedDuctEdgeId ? { ...e, ...updates } : e));
  };

  const deleteSelectedDuctEdge = () => {
    if (!selectedDuctEdgeId) return;
    pushHistory();
    setDuctEdges(prev => prev.filter(e => e.id !== selectedDuctEdgeId));
    setTimeout(() => {
      setDuctNodes(prev => prev.filter(n => {
        return ductEdges.some(e => e.id !== selectedDuctEdgeId && (e.startId === n.id || e.endId === n.id));
      }));
    }, 0);
    setSelectedDuctEdgeId(null);
  };

  const updateStartNodeLevel = (newLevel) => {
    if (!selectedEdge) return;
    pushHistory();
    setNodes(prev => prev.map(n => n.id === selectedEdge.startId ? { ...n, level: newLevel } : n));
  };

  const updateEndNodeLevel = (newLevel) => {
    if (!selectedEdge) return;
    pushHistory();
    setNodes(prev => prev.map(n => n.id === selectedEdge.endId ? { ...n, level: newLevel } : n));
  };

  const deleteSelectedEdge = () => {
    if (!selectedEdgeId) return;
    pushHistory();
    setEdges(prev => prev.filter(e => e.id !== selectedEdgeId));
    setTimeout(() => {
      setNodes(prev => prev.filter(n => {
        return edges.some(e => e.id !== selectedEdgeId && (e.startId === n.id || e.endId === n.id));
      }));
    }, 0);
    setSelectedEdgeId(null);
  };

  const updateSelectedFrame = (updates) => {
    pushHistory();
    setFrames(prev => prev.map(f => f.id === selectedFrameId ? { ...f, ...updates } : f));
  };

  const deleteSelectedFrame = () => {
    if (!selectedFrameId) return;
    pushHistory();
    setFrames(prev => prev.filter(f => f.id !== selectedFrameId));
    setSelectedFrameId(null);
  };

  const updateSelectedEquipment = (updates) => {
    pushHistory();
    setEquipments(prev => prev.map(eq => eq.id === selectedEquipmentId ? { ...eq, ...updates } : eq));
  };

  const deleteSelectedEquipment = () => {
    if (!selectedEquipmentId) return;
    pushHistory();
    setEquipments(prev => prev.filter(eq => eq.id !== selectedEquipmentId));
    setSelectedEquipmentId(null);
  };

  const clearAll = () => {
    if (!confirm('すべての配管・ダクトを削除しますか?')) return;
    pushHistory();
    setNodes([]);
    setEdges([]);
    setDuctNodes([]);
    setDuctEdges([]);
    setSelectedEdgeId(null);
    setSelectedDuctEdgeId(null);
    setDrawingFromId(null);
    setDrawingDuctFromId(null);
  };

  // 拾い集計:配管・ダクト・継手を種別・系統ごとに集計
  // 出力:
  //   - pipes: 管種×口径ごとの本数と総延長
  //   - fittings: 継手種類×口径ごとの個数
  //   - ducts: ダクト種別×サイズごとの本数と総延長
  //   - ductFittings: ダクト継手の集計
  //   - pipeSystems: 系統ごとの集計(配管)
  //   - ductSystems: 系統ごとの集計(ダクト)
  // 用途: 集計画面の表示、Excel出力の元データ
  const summary = useMemo(() => {
    const pipeMap = {};
    edges.forEach(e => {
      const lv = edgeLevels[e.id];
      if (!lv) return;
      const key = `${e.pipeType}-${e.diameter}`;
      if (!pipeMap[key]) {
        pipeMap[key] = { pipeType: e.pipeType, diameter: e.diameter, count: 0, totalLength: 0 };
      }
      pipeMap[key].count += 1;
      pipeMap[key].totalLength += lv.length;
    });
    const fittingMap = {};
    Object.entries(nodeFittingTypes).forEach(([nodeId, type]) => {
      if (type === 'elbow' || type === 'tee' || type === 'cross') {
        const connectedEdge = edges.find(e => e.startId === nodeId || e.endId === nodeId);
        const diameter = connectedEdge ? connectedEdge.diameter : '-';
        const typeLabel = type === 'elbow' ? 'エルボ' : type === 'tee' ? 'チーズ' : 'クロス';
        const key = `${typeLabel}-${diameter}`;
        if (!fittingMap[key]) {
          fittingMap[key] = { type: typeLabel, diameter, count: 0 };
        }
        fittingMap[key].count += 1;
      }
    });

    // ダクト集計
    const ductMap = {};
    ductEdges.forEach(e => {
      const n1 = ductNodes.find(n => n.id === e.startId);
      const n2 = ductNodes.find(n => n.id === e.endId);
      if (!n1 || !n2) return;
      const lenMM = distanceMM(n1, n2);
      const sizeLabel = e.shape === 'round' ? `φ${e.size.d}` : `${e.size.w}×${e.size.h}`;
      const key = `${e.ductType}-${sizeLabel}`;
      if (!ductMap[key]) {
        ductMap[key] = { ductType: e.ductType, size: sizeLabel, shape: e.shape, count: 0, totalLength: 0 };
      }
      ductMap[key].count += 1;
      ductMap[key].totalLength += lenMM;
    });
    // ダクト継手集計
    const ductFittingMap = {};
    Object.entries(ductNodeFittingTypes).forEach(([nodeId, type]) => {
      if (type === 'elbow' || type === 'tee' || type === 'cross') {
        const connectedEdge = ductEdges.find(e => e.startId === nodeId || e.endId === nodeId);
        const sizeLabel = connectedEdge
          ? (connectedEdge.shape === 'round' ? `φ${connectedEdge.size.d}` : `${connectedEdge.size.w}×${connectedEdge.size.h}`)
          : '-';
        const typeLabel = type === 'elbow' ? 'エルボ' : type === 'tee' ? 'チーズ' : 'クロス';
        const key = `${typeLabel}-${sizeLabel}`;
        if (!ductFittingMap[key]) {
          ductFittingMap[key] = { type: typeLabel, size: sizeLabel, count: 0 };
        }
        ductFittingMap[key].count += 1;
      }
    });

    // 系統別集計(配管)
    const pipeSystemMap = {};
    edges.forEach(e => {
      const lv = edgeLevels[e.id];
      if (!lv) return;
      const sys = e.system || '(未設定)';
      if (!pipeSystemMap[sys]) {
        pipeSystemMap[sys] = { system: sys, types: new Set(), count: 0, totalLength: 0 };
      }
      pipeSystemMap[sys].types.add(`${e.pipeType}${e.diameter}`);
      pipeSystemMap[sys].count += 1;
      pipeSystemMap[sys].totalLength += lv.length;
    });

    // 系統別集計(ダクト)
    const ductSystemMap = {};
    ductEdges.forEach(e => {
      const n1 = ductNodes.find(n => n.id === e.startId);
      const n2 = ductNodes.find(n => n.id === e.endId);
      if (!n1 || !n2) return;
      const lenMM = distanceMM(n1, n2);
      const sys = e.system || '(未設定)';
      const sizeLabel = e.shape === 'round' ? `φ${e.size.d}` : `${e.size.w}×${e.size.h}`;
      if (!ductSystemMap[sys]) {
        ductSystemMap[sys] = { system: sys, types: new Set(), count: 0, totalLength: 0 };
      }
      ductSystemMap[sys].types.add(`${e.ductType}${sizeLabel}`);
      ductSystemMap[sys].count += 1;
      ductSystemMap[sys].totalLength += lenMM;
    });

    return {
      pipes: Object.values(pipeMap).sort((a, b) => a.pipeType.localeCompare(b.pipeType)),
      fittings: Object.values(fittingMap).sort((a, b) => a.type.localeCompare(b.type)),
      ducts: Object.values(ductMap).sort((a, b) => a.ductType.localeCompare(b.ductType)),
      ductFittings: Object.values(ductFittingMap).sort((a, b) => a.type.localeCompare(b.type)),
      pipeSystems: Object.values(pipeSystemMap).map(s => ({ ...s, typesText: Array.from(s.types).join(', ') })).sort((a, b) => a.system.localeCompare(b.system)),
      ductSystems: Object.values(ductSystemMap).map(s => ({ ...s, typesText: Array.from(s.types).join(', ') })).sort((a, b) => a.system.localeCompare(b.system)),
    };
  }, [edges, edgeLevels, nodeFittingTypes, ductEdges, ductNodes, ductNodeFittingTypes]);

  const selectedEdge = edges.find(e => e.id === selectedEdgeId);
  const selectedDuctEdge = ductEdges.find(e => e.id === selectedDuctEdgeId);
  const selectedFrame = frames.find(f => f.id === selectedFrameId);
  const selectedEquipment = equipments.find(eq => eq.id === selectedEquipmentId);

  const viewBox = `${view.x} ${view.y} ${view.w} ${view.h}`;

  // アイソメ用のビューボックス計算:
  // すべての要素(躯体・配管・ダクト・機器)の3D頂点をアイソメ変換し、その包絡矩形を求める
  // パン/ズームのために view を使うのではなく、アイソメは固定スケールで全体表示
  const isoViewBox = useMemo(() => {
    if (viewMode !== 'iso') return null;
    const pts = [];
    frames.forEach(fr => {
      const v = isoBoxVertices(fr.x, fr.y, fr.w, fr.h, fr.bottomFL, fr.topFL);
      Object.values(v).forEach(p => pts.push(p));
    });
    equipments.forEach(eq => {
      const v = isoBoxVertices(eq.x, eq.y, eq.w, eq.h, eq.bottomFL, eq.topFL);
      Object.values(v).forEach(p => pts.push(p));
    });
    // 配管:各エッジの始点・終点・高さで頂点を生成
    edges.forEach(e => {
      const n1 = nodes.find(n => n.id === e.startId);
      const n2 = nodes.find(n => n.id === e.endId);
      if (!n1 || !n2) return;
      const lv = edgeLevels[e.id];
      if (!lv) return;
      pts.push(toIso(n1.x, n1.y, lv.startLv));
      pts.push(toIso(n2.x, n2.y, lv.endLv));
    });
    // ダクト:同様
    ductEdges.forEach(de => {
      const n1 = ductNodes.find(n => n.id === de.startId);
      const n2 = ductNodes.find(n => n.id === de.endId);
      if (!n1 || !n2) return;
      const r = ductHeightRange(de.level, de.shape, de.size);
      pts.push(toIso(n1.x, n1.y, r.low));
      pts.push(toIso(n1.x, n1.y, r.high));
      pts.push(toIso(n2.x, n2.y, r.low));
      pts.push(toIso(n2.x, n2.y, r.high));
    });
    if (pts.length === 0) {
      return '-400 -300 800 600';
    }
    const xs = pts.map(p => p.x);
    const ys = pts.map(p => p.y);
    const minX = Math.min(...xs);
    const maxX = Math.max(...xs);
    const minY = Math.min(...ys);
    const maxY = Math.max(...ys);
    const padding = 30;
    const w = maxX - minX + padding * 2;
    const h = maxY - minY + padding * 2;
    return `${minX - padding} ${minY - padding} ${w} ${h}`;
  }, [viewMode, frames, equipments, edges, nodes, edgeLevels, ductEdges, ductNodes]);
  let svgClass = `mode-${mode}`;
  if (isPanning) svgClass += ' panning-active';

  return (
    <React.Fragment>
      <div className="header">
        <div className="header-left">
          <div className="header-title">Rebro Lite</div>
          <input
            type="text"
            className="project-name-input"
            value={projectName}
            onChange={e => setProjectName(e.target.value)}
            placeholder="プロジェクト名"
          />
          <button
            className="header-btn"
            onClick={undo}
            disabled={history.length === 0}
            title="1つ前の状態に戻す(Ctrl+Z)"
            style={{ opacity: history.length === 0 ? 0.4 : 1 }}
          >↶ 戻る</button>
          <button className="header-btn primary" onClick={saveProject}>保存</button>
          <div className="menu-wrap">
            <button className="header-btn" onClick={() => setMenuOpen(!menuOpen)}>メニュー ▾</button>
            {menuOpen && (
              <div className="menu-dropdown">
                <div className="menu-section">
                  <div className="menu-section-title">プロジェクト</div>
                  <div className="menu-item" onClick={() => { newProject(); setMenuOpen(false); }}>新規プロジェクト</div>
                  <div className="menu-item" onClick={() => { setModalType('load'); setMenuOpen(false); }}>保存済みから開く</div>
                  <div className="menu-item" onClick={() => { setModalType('samples'); setMenuOpen(false); }}>サンプルから開く</div>
                </div>
                <div className="menu-section">
                  <div className="menu-section-title">ファイル</div>
                  <div className="menu-item" onClick={() => { exportJson(); setMenuOpen(false); }}>JSONエクスポート</div>
                  <div className="menu-item" onClick={() => { fileInputRef.current?.click(); setMenuOpen(false); }}>JSONインポート</div>
                </div>
              </div>
            )}
          </div>
          <input
            ref={fileInputRef}
            type="file"
            accept=".json"
            style={{display: 'none'}}
            onChange={e => {
              const file = e.target.files?.[0];
              if (file) importJson(file);
              e.target.value = '';
            }}
          />
        </div>
        <div className="tabs">
          <button
            className={`tab ${viewMode === 'iso' ? 'active' : ''}`}
            onClick={() => setViewMode(viewMode === 'plan' ? 'iso' : 'plan')}
            title="平面図とアイソメ図(等角投影)を切り替え"
            style={{marginRight: '12px', background: viewMode === 'iso' ? '#805ad5' : '#4a5568'}}
          >
            {viewMode === 'iso' ? '◆ アイソメ' : '▭ 平面'}
          </button>
          <button className={`tab ${mode === 'draw' ? 'active' : ''}`} onClick={() => changeMode('draw')}>配管</button>
          <button className={`tab ${mode === 'duct' ? 'active' : ''}`} onClick={() => changeMode('duct')}>ダクト</button>
          <button className={`tab ${mode === 'frame' ? 'active' : ''}`} onClick={() => changeMode('frame')}>躯体</button>
          <button className={`tab ${mode === 'equipment' ? 'active' : ''}`} onClick={() => changeMode('equipment')}>機器</button>
          <button className={`tab ${mode === 'select' ? 'active' : ''}`} onClick={() => changeMode('select')}>選択</button>
          <button className={`tab ${mode === 'clash' ? 'active' : ''}`} onClick={() => changeMode('clash')}>干渉</button>
          <button className={`tab ${mode === 'summary' ? 'active' : ''}`} onClick={() => changeMode('summary')}>集計</button>
        </div>
      </div>

      <div className="main">
        <div className="sidebar-left">
          {mode === 'frame' ? (
            <React.Fragment>
              <div className="sidebar-section">
                <div className="sidebar-section-title">躯体種別</div>
                <div className={`sidebar-item ${frameType === 'beam' ? 'active-frame' : ''}`} onClick={() => startFrameAdd('beam')}>
                  <span style={{display: 'inline-block', width: '14px', height: '6px', background: FRAME_COLORS.beam, marginRight: '6px', verticalAlign: 'middle', border: '1px solid #888'}}></span>
                  梁
                </div>
                <div className={`sidebar-item ${frameType === 'column' ? 'active-frame' : ''}`} onClick={() => startFrameAdd('column')}>
                  <span style={{display: 'inline-block', width: '10px', height: '10px', background: FRAME_COLORS.column, marginRight: '6px', verticalAlign: 'middle', border: '1px solid #888'}}></span>
                  柱
                </div>
              </div>
              <div className="sidebar-section">
                <div className="sidebar-section-title">操作</div>
                <div className="sidebar-item" onClick={resetView}>表示リセット</div>
              </div>
              <div className="legend-box" style={{fontSize: '10px', lineHeight: 1.6}}>
                <b>使い方:</b><br/>
                ・種別を選択<br/>
                ・キャンバスで対角の2点をクリック<br/>
                ・選択モードで個別編集可能<br/><br/>
                <b>初期値:</b><br/>
                ・梁: FL+2300〜+2800<br/>
                ・柱: FL+0〜+3000
              </div>
            </React.Fragment>
          ) : mode === 'duct' ? (
            <React.Fragment>
