                //     - 中区間がない → 制約なし(null)
                //
                // まずエッジ内の「中区間」(梁と平面で重なる区間)の midSy を集めて、
                // 平面で重ならない区間の near/far 判定の基準にする
                const middleSegmentMidSyList = [];
                segs.forEach(s => {
                  if (s.planeFrameMeta.length > 0) middleSegmentMidSyList.push(s.midSy);
                });
                const middleMaxSy = middleSegmentMidSyList.length > 0 ? Math.max(...middleSegmentMidSyList) : null;
                const middleMinSy = middleSegmentMidSyList.length > 0 ? Math.min(...middleSegmentMidSyList) : null;
                segs.forEach(s => {
                  if (s.planeFrameMeta.length === 0) {
                    // この区間は梁と平面で重ならない(=エッジの両端側)
                    if (middleMaxSy === null) {
                      // エッジ内に中区間がない → 制約なし
                      s.constraintFrameIds = [];
                      s.position = null;
                    } else {
                      // 中区間と比較して near/far を決める
                      // 自分の midSy が中区間より画面で手前(大きい) → near、奥(小さい) → far
                      s.constraintFrameIds = Array.from(frameIds);
                      s.position = s.midSy >= middleMaxSy ? 'near' : 'far';
                    }
                    return;
                  }
                  // この区間は梁と平面で重なる中区間
                  s.constraintFrameIds = s.planeFrameMeta.map(m => m.frameId);
                  // through / below / above のいずれかを含むかで判定
                  const hasBelow = s.planeFrameMeta.some(m => m.posVsFrame === 'below');
                  const hasThrough = s.planeFrameMeta.some(m => m.posVsFrame === 'through');
                  const hasAbove = s.planeFrameMeta.some(m => m.posVsFrame === 'above');
                  if (hasBelow || hasThrough) {
                    // 梁の下 or 貫通 → 梁の前に描画 = far
                    s.position = 'far';
                  } else if (hasAbove) {
                    // 梁の上を通る → 梁の後に描画 = near
                    s.position = 'near';
                  } else {
                    // 上記いずれでもない(理論上ありえない、防御的)
                    s.position = null;
                  }
                });
                // 配管エッジの端点情報(接続判定用、nodes から取得)
                const e = segs[0].data;
                const n1 = nodes.find(n => n.id === e.startId);
                const n2 = nodes.find(n => n.id === e.endId);
                let backNodeId = null, frontNodeId = null;
                if (n1 && n2) {
                  const lv = edgeLevels[e.id];
                  if (lv) {
                    const p1 = toIso(n1.x, n1.y, lv.startLv);
                    const p2 = toIso(n2.x, n2.y, lv.endLv);
                    if (p1.y < p2.y) {
                      backNodeId = n1.id; frontNodeId = n2.id;
                    } else if (p1.y > p2.y) {
                      backNodeId = n2.id; frontNodeId = n1.id;
                    }
                  }
                }
                edgeInfo[makeEdgeKey('pipe', eid)] = {
                  kind: 'pipe',
                  segments: segs,
                  frameIds: Array.from(frameIds),
                  repSy,
                  backNodeId,
                  frontNodeId,
                  edgeData: e
                };
              });

              // ダクトエッジを集約(配管と同じロジック)
              const ductEdgeIdSet = new Set(ductUnits.map(u => u.edgeId));
              ductEdgeIdSet.forEach(eid => {
                const segs = ductUnits.filter(u => u.edgeId === eid);
                const frameIds = new Set();
                let repSy = -Infinity;
                segs.forEach(s => {
                  s.planeFrameMeta.forEach(m => frameIds.add(m.frameId));
                  if (s.midSy > repSy) repSy = s.midSy;
                });
                // 各区間に position と constraintFrameIds を割り当て(配管と同じ新ルール)
                const middleSegmentMidSyList = [];
                segs.forEach(s => {
                  if (s.planeFrameMeta.length > 0) middleSegmentMidSyList.push(s.midSy);
                });
                const middleMaxSy = middleSegmentMidSyList.length > 0 ? Math.max(...middleSegmentMidSyList) : null;
                segs.forEach(s => {
                  if (s.planeFrameMeta.length === 0) {
                    if (middleMaxSy === null) {
                      s.constraintFrameIds = [];
                      s.position = null;
                    } else {
                      s.constraintFrameIds = Array.from(frameIds);
                      s.position = s.midSy >= middleMaxSy ? 'near' : 'far';
                    }
                    return;
                  }
                  s.constraintFrameIds = s.planeFrameMeta.map(m => m.frameId);
                  const hasBelow = s.planeFrameMeta.some(m => m.posVsFrame === 'below');
                  const hasThrough = s.planeFrameMeta.some(m => m.posVsFrame === 'through');
                  const hasAbove = s.planeFrameMeta.some(m => m.posVsFrame === 'above');
                  if (hasBelow || hasThrough) {
                    s.position = 'far';
                  } else if (hasAbove) {
                    s.position = 'near';
                  } else {
                    s.position = null;
                  }
                });
                // ダクトエッジの端点情報(ductNodes から取得)
                const de = segs[0].data;
                const dn1 = ductNodes.find(n => n.id === de.startId);
                const dn2 = ductNodes.find(n => n.id === de.endId);
                let backNodeId = null, frontNodeId = null;
                if (dn1 && dn2) {
                  const p1 = toIso(dn1.x, dn1.y, de.level);
                  const p2 = toIso(dn2.x, dn2.y, de.level);
                  if (p1.y < p2.y) {
                    backNodeId = dn1.id; frontNodeId = dn2.id;
                  } else if (p1.y > p2.y) {
                    backNodeId = dn2.id; frontNodeId = dn1.id;
                  }
                }
                edgeInfo[makeEdgeKey('duct', eid)] = {
                  kind: 'duct',
                  segments: segs,
                  frameIds: Array.from(frameIds),
                  repSy,
                  backNodeId,
                  frontNodeId,
                  edgeData: de
                };
              });

              // ----- ステップ 2.5:エッジ間の接続制約を構築 -----
              // 配管・ダクト それぞれ別ドメインで制約を構築(配管とダクトは接続しないので相互参照なし)
              // 接続制約 G[edgeKey] = { ge: Set<edgeKey>, le: Set<edgeKey> }
              //   ge: A の序列番号 ≥ B (A は B 以降に配置)
              //   le: A の序列番号 ≤ B (A は B 以前に配置)
              const edgeKeys = Object.keys(edgeInfo);
              const constraintsG = {};
              edgeKeys.forEach(ek => { constraintsG[ek] = { ge: new Set(), le: new Set() }; });
              edgeKeys.forEach(ekA => {
                const a = edgeInfo[ekA];
                edgeKeys.forEach(ekB => {
                  if (ekA === ekB) return;
                  const b = edgeInfo[ekB];
                  // 配管同士・ダクト同士でのみ接続制約を構築(別ドメインは無関係)
                  if (a.kind !== b.kind) return;
                  // A の奥側端点が B の端点と一致?
                  if (a.backNodeId && (a.backNodeId === b.edgeData.startId || a.backNodeId === b.edgeData.endId)) {
                    constraintsG[ekA].ge.add(ekB);
                  }
                  // A の手前側端点が B の端点と一致?
                  if (a.frontNodeId && (a.frontNodeId === b.edgeData.startId || a.frontNodeId === b.edgeData.endId)) {
                    constraintsG[ekA].le.add(ekB);
                  }
                });
              });

              // ----- ステップ 3:配管エッジを序列に挿入 -----
              // 各エッジの seq(序列番号、整数)を決める。
              // 候補:固定要素の中で、エッジの repSy 直後の位置(自然位置)
              // 制約A(貫通梁):そのエッジが貫通する梁の seq より大きい(エッジは貫通梁より後)
              //   注:貫通区間 within / near は梁より後、far は梁より前という関係だが、
              //       エッジ単位の seq としては「最後の区間の位置 = near の位置」を基準にして「梁より後」とする。
              //       far は同じエッジ内で梁より前に展開するので、エッジの seq には影響しない。
              // 制約B(接続):上記 constraintsG に従う
              //
              // 解き方:配管エッジを repSy 順に並べ、各エッジについて seq の最小値を計算
              //   minSeq = max(
              //     貫通梁の seq + 1,             // 制約A
              //     constraintsG[eid].ge にあるエッジの seq, // 制約B (ge)
              //     固定要素の repSy 自然位置  // 制約C
              //   )
              //   maxSeq = min(
              //     constraintsG[eid].le にあるエッジの seq,  // 制約B (le)
              //   )
              //   seq = clamp(自然位置, minSeq, maxSeq)
              //
              // 注:接続制約 ge/le は他のエッジに依存するので、依存関係に従って解く必要がある。
              // → 依存グラフをトポロジカルソートして、依存先から順に解く。

              // 簡易化:repSy 順(奥から手前)に配管エッジを処理する
              // ge 制約(自分が他のエッジ B より後)の B はすでに処理済みである必要があるが、
              // repSy が小さい(B が奥)なら B が先に処理される自然な順序
              // le 制約(自分が他のエッジ B より前)は repSy 大きい順なので、後で処理する B との関係になり、
              // この時点では B の seq が未確定。これは「制約 le があるエッジは seq を後で再調整」で対応する。

              const sortedEdgeKeys = edgeKeys.slice().sort((a, b) => edgeInfo[a].repSy - edgeInfo[b].repSy);
              const edgeSeq = {}; // edgeKey → seq (固定要素の序列を基準とした整数)

              // 「固定要素の序列で repSy に最も近い直後の位置」を計算するヘルパー
              // 戻り値:エッジが入る「位置候補」(整数。固定要素の seq の隙間に入る感覚で、その値以上に配置)
              const findNaturalSlot = (sy) => {
                // fixedUnits は seq 昇順で並んでいる。sy が小さい(奥) → 序列の前、大きい(手前) → 後
                // sy 以下の最後の固定要素の seq + 1 が候補
                let slot = 0;
                for (let i = 0; i < fixedUnits.length; i++) {
                  if (fixedUnits[i].sortKey <= sy) {
                    slot = fixedUnits[i].seq + 1;
                  } else {
                    break;
                  }
                }
                return slot;
              };

              // 第1パス:制約 A(貫通梁)と repSy 自然位置で初期 seq を決める
              sortedEdgeKeys.forEach(ek => {
                const info = edgeInfo[ek];
                let minSeq = findNaturalSlot(info.repSy); // 制約C(自然位置)
                // 制約A:貫通梁より後(梁の seq + 1 以上)
                info.frameIds.forEach(fid => {
                  const frameUnit = fixedUnits.find(u => u.kind === 'frame' && u.data.id === fid);
                  if (frameUnit) {
                    minSeq = Math.max(minSeq, frameUnit.seq + 1);
                  }
                });
                edgeSeq[ek] = minSeq;
              });

              // 第2パス:制約 B を満たすまで繰り返し調整(最大10回イテレーション)
              // 制約 ge(自分は B より後):自分の seq ≥ B の seq
              // 制約 le(自分は B より前):自分の seq ≤ B の seq
              // ge を満たすために自分の seq を上げる方が安全(制約 A・C と整合しやすい)
              for (let iter = 0; iter < 10; iter++) {
                let changed = false;
                sortedEdgeKeys.forEach(ek => {
                  let cur = edgeSeq[ek];
                  // ge 制約:cur が B の seq より小さければ、cur を上げる
                  constraintsG[ek].ge.forEach(bk => {
                    if (edgeSeq[bk] !== undefined && cur < edgeSeq[bk]) {
                      cur = edgeSeq[bk];
                      changed = true;
                    }
                  });
                  edgeSeq[ek] = cur;
                });
                if (!changed) break;
              }

              // ----- ステップ 4:最終列を構築 -----
              // 各序列位置に対し、その位置にある全ユニットを集める
              // - 固定要素:seq 順
              // - 配管/ダクトエッジ:edgeSeq[ek] 順
              // 配管/ダクトエッジは「far区間 → 関連梁 → near区間」の順序を内部で守る必要がある
              // ただし関連梁は既に固定要素として配置済みなので、配管区間だけを正しい位置に配置する
              //
              // 配管/ダクト区間のpositionと配置位置:
              //   far    → 関連梁の最小seq の直前(梁の前に描画、梁に隠れる)
              //   near   → エッジの seq + 0.3(梁の後ろに描画、梁の上に乗る)
              //   null   → エッジの seq + 0.5(制約なし)

              const finalUnits = [];
              // 固定要素を seq でマップに入れる
              fixedUnits.forEach(u => {
                finalUnits.push({ unit: u, finalSeq: u.seq });
              });

              // 配管区間とダクト区間を統合して finalSeq に従って配置するヘルパー
              const placeMovableUnit = (u, ek) => {
                const eseq = edgeSeq[ek];
                let finalSeq;
                if (u.position === 'far') {
                  // 関連梁の最小 seq の直前(梁の前に描画 → 梁が後で上塗りされて隠れる)
                  let minFrameSeq = Infinity;
                  u.constraintFrameIds.forEach(fid => {
                    const fu = fixedUnits.find(fx => fx.kind === 'frame' && fx.data.id === fid);
                    if (fu && fu.seq < minFrameSeq) minFrameSeq = fu.seq;
                  });
                  finalSeq = (minFrameSeq !== Infinity) ? minFrameSeq - 0.5 : eseq - 0.5;
                } else if (u.position === 'near') {
                  // エッジ全体の seq + 微小オフセット(梁より後、梁の上に乗る)
                  finalSeq = eseq + 0.3;
                } else {
                  // 制約なし
                  finalSeq = eseq + 0.5;
                }
                finalUnits.push({ unit: u, finalSeq });
              };

              // 配管区間を配置
              pipeUnits.forEach(u => placeMovableUnit(u, makeEdgeKey('pipe', u.edgeId)));
              // ダクト区間を配置(配管と同じく全区間描画。far扱いの中区間は梁に隠れる効果が出る)
              ductUnits.forEach(u => placeMovableUnit(u, makeEdgeKey('duct', u.edgeId)));

              // finalSeq 昇順でソート(奥から手前)
              finalUnits.sort((a, b) => a.finalSeq - b.finalSeq);

              // units を最終順序で置き換え
              units.length = 0;
              finalUnits.forEach(fu => units.push(fu.unit));

              return units.map((unit, idx) => {
                if (unit.kind === 'frame') {
                  const fr = unit.data;
                  const baseColor = FRAME_COLORS[fr.type];
                  const v = unit.vertices;
                  const topPath = `M${v.tlf.x},${v.tlf.y} L${v.trf.x},${v.trf.y} L${v.trb.x},${v.trb.y} L${v.tlb.x},${v.tlb.y} Z`;
                  const frontPath = `M${v.blf.x},${v.blf.y} L${v.brf.x},${v.brf.y} L${v.trf.x},${v.trf.y} L${v.tlf.x},${v.tlf.y} Z`;
                  const rightPath = `M${v.brf.x},${v.brf.y} L${v.brb.x},${v.brb.y} L${v.trb.x},${v.trb.y} L${v.trf.x},${v.trf.y} Z`;
                  return (
                    <g key={`iso-fr-${fr.id}-${idx}`}>
                      <path d={rightPath} fill={shadeColor(baseColor, 0.7)} stroke="#555" strokeWidth="0.5"/>
                      <path d={frontPath} fill={shadeColor(baseColor, 0.85)} stroke="#555" strokeWidth="0.5"/>
                      <path d={topPath} fill={shadeColor(baseColor, 1.0)} stroke="#555" strokeWidth="0.5"/>
                    </g>
                  );
                }
                if (unit.kind === 'equipment') {
                  const eq = unit.data;
                  const def = EQUIPMENT_DEFS[eq.equipType] || { color: '#888' };
                  const baseColor = def.color;
                  const v = unit.vertices;
                  const topPath = `M${v.tlf.x},${v.tlf.y} L${v.trf.x},${v.trf.y} L${v.trb.x},${v.trb.y} L${v.tlb.x},${v.tlb.y} Z`;
                  const frontPath = `M${v.blf.x},${v.blf.y} L${v.brf.x},${v.brf.y} L${v.trf.x},${v.trf.y} L${v.tlf.x},${v.tlf.y} Z`;
                  const rightPath = `M${v.brf.x},${v.brf.y} L${v.brb.x},${v.brb.y} L${v.trb.x},${v.trb.y} L${v.trf.x},${v.trf.y} Z`;
                  const labelPt = toIso(eq.x + eq.w / 2, eq.y + eq.h / 2, eq.topFL);
                  return (
                    <g key={`iso-eq-${eq.id}-${idx}`}>
                      <path d={rightPath} fill={shadeColor(baseColor, 0.7)} stroke="#444" strokeWidth="0.7"/>
                      <path d={frontPath} fill={shadeColor(baseColor, 0.85)} stroke="#444" strokeWidth="0.7"/>
                      <path d={topPath} fill={shadeColor(baseColor, 1.0)} stroke="#444" strokeWidth="0.7"/>
                      <text x={labelPt.x} y={labelPt.y - 2} textAnchor="middle" fontSize="7" fill="#222" style={{pointerEvents: 'none'}}>{eq.name}</text>
                    </g>
                  );
                }
                if (unit.kind === 'duct') {
                  const de = unit.data;
                  const v = unit.vertices;
                  const baseColor = DUCT_COLORS[de.ductType];
                  const topPath = `M${v.tlf.x},${v.tlf.y} L${v.trf.x},${v.trf.y} L${v.trb.x},${v.trb.y} L${v.tlb.x},${v.tlb.y} Z`;
                  const frontPath = `M${v.blf.x},${v.blf.y} L${v.brf.x},${v.brf.y} L${v.trf.x},${v.trf.y} L${v.tlf.x},${v.tlf.y} Z`;
                  const rightPath = `M${v.brf.x},${v.brf.y} L${v.brb.x},${v.brb.y} L${v.trb.x},${v.trb.y} L${v.trf.x},${v.trf.y} Z`;
                  return (
                    <g key={`iso-de-${de.id}-${idx}`}>
                      <path d={rightPath} fill={shadeColor(baseColor, 0.7)} fillOpacity="0.85" stroke="#333" strokeWidth="0.5"/>
                      <path d={frontPath} fill={shadeColor(baseColor, 0.85)} fillOpacity="0.85" stroke="#333" strokeWidth="0.5"/>
                      <path d={topPath} fill={shadeColor(baseColor, 1.0)} fillOpacity="0.85" stroke="#333" strokeWidth="0.5" strokeDasharray={de.shape === 'round' ? '2 1' : null}/>
                    </g>
                  );
                }
                if (unit.kind === 'pipe') {
                  const e = unit.data;
                  const baseColor = PIPE_COLORS[e.pipeType];
                  // 配管は常に実線で描画。描画順で梁に隠れる(far)/梁の上に乗る(near)を表現する
                  return (
                    <line key={`iso-pipe-${e.id}-${idx}`}
                      x1={unit.p1.x} y1={unit.p1.y} x2={unit.p2.x} y2={unit.p2.y}
                      stroke={baseColor}
                      strokeWidth="3"
                      strokeLinecap="round"
                      opacity="0.95"
                    />
                  );
                }
                return null;
              });
            })()}
          </svg>

          <div className="zoom-controls">
            <button className="zoom-btn" onClick={zoomIn} title="拡大">+</button>
            <button className="zoom-btn" onClick={zoomOut} title="縮小">−</button>
            <button className="zoom-btn" onClick={resetView} title="表示リセット" style={{fontSize: '11px'}}>⛶</button>
          </div>

          <div className="floor-info">
            <div><b>{FLOOR_CONFIG.name}</b> 階高 <b>{FLOOR_CONFIG.floorHeight}</b></div>
            <div>CH <b>{FLOOR_CONFIG.ceilingHeight}</b> 天井懐 <b>{FLOOR_CONFIG.floorHeight - FLOOR_CONFIG.ceilingHeight}</b></div>
          </div>

          {viewMode === 'iso' && (
            <div className="hint">アイソメ図(等角投影)/ 確認専用ビュー / 編集する場合は「▭ 平面」に戻してください</div>
          )}
          {viewMode === 'plan' && mode === 'draw' && !drawingFromId && (
            <div className="hint">クリックで配管描画 / 配管レベルを左で設定 / ホイール拡大縮小 / Shift+ドラッグでパン</div>
          )}
          {viewMode === 'plan' && mode === 'draw' && drawingFromId && (() => {
            const from = nodes.find(n => n.id === drawingFromId);
            if (!from) return null;
            const fromLv = from.level || currentLevel;
            if (isSlopedPipe(currentPipeType) && mousePos) {
              const lenMM = distanceMM(from, mousePos);
              const endLv = calcEndLevel(fromLv, SLOPE_DEFAULTS[currentPipeType], lenMM);
              return <div className="hint">始点 FL+{fromLv} / 終点 FL+{endLv} / 落差 {fromLv - endLv}mm / 配管長 {Math.round(lenMM)}mm / 勾配 {slopeRatioToText(SLOPE_DEFAULTS[currentPipeType])}</div>;
            }
            return <div className="hint">配管レベル FL+{fromLv}(水平) / 右クリックまたはEscで終了</div>;
          })()}
          {viewMode === 'plan' && mode === 'duct' && !drawingDuctFromId && (
            <div className="hint">クリックでダクト描画 / 種別・形状・サイズ・レベルを左で設定 / ホイール拡大縮小 / Shift+ドラッグでパン</div>
          )}
          {viewMode === 'plan' && mode === 'duct' && drawingDuctFromId && (() => {
            const from = ductNodes.find(n => n.id === drawingDuctFromId);
            if (!from) return null;
            const sizeLabel = currentDuctShape === 'round' ? `φ${currentDuctSize.d}` : `${currentDuctSize.w}×${currentDuctSize.h}`;
            const len = mousePos ? distanceMM(from, mousePos) : 0;
            return <div className="hint">{currentDuctType} {sizeLabel} / FL+{currentDuctLevel}(水平) / 長さ {Math.round(len)}mm / 右クリックまたはEscで終了</div>;
          })()}
          {viewMode === 'plan' && mode === 'frame' && !frameType && <div className="hint">左サイドバーで「梁」または「柱」を選択してください</div>}
          {viewMode === 'plan' && mode === 'frame' && frameType && !frameStart && <div className="hint">{FRAME_LABELS[frameType]}の1点目をクリック</div>}
          {viewMode === 'plan' && mode === 'frame' && frameType && frameStart && <div className="hint">対角の2点目をクリックで{FRAME_LABELS[frameType]}を確定 / Escでキャンセル</div>}
          {viewMode === 'plan' && mode === 'equipment' && !equipmentType && <div className="hint">左サイドバーで機器種別を選択してください</div>}
          {viewMode === 'plan' && mode === 'equipment' && equipmentType && <div className="hint">クリック位置を中心に{EQUIPMENT_DEFS[equipmentType].label}を配置 / 連続クリックで複数配置 / Escでキャンセル</div>}
          {viewMode === 'plan' && mode === 'select' && !selectedEdgeId && !selectedDuctEdgeId && !selectedFrameId && !selectedEquipmentId && <div className="hint">配管・ダクト・躯体・機器をクリックして選択</div>}
