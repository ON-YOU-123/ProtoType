<body>
<div id="root"></div>

<script type="text/babel">
const { useState, useRef, useEffect, useMemo, useCallback } = React;

// ===== 設定 =====
const FLOOR_CONFIG = {
  name: '3F',
  floorHeight: 3000,
  ceilingHeight: 2700,
};

// ===== 描画・色の定数 =====
// 躯体(建築構造体)の色設定。梁・柱とも建築図面で使われる薄いベージュ系
const FRAME_COLORS = { beam: '#b8b5a0', column: '#9b9580' };
const FRAME_LABELS = { beam: '梁', column: '柱' };

// 配管種別と色設定
// 設備設計の慣例的な色分け:給水=青、排水=紫、冷温水=緑、ドレン=水色、電気=橙
const PIPE_TYPES = ['給水', '排水', '冷温水', 'ドレン', '電気'];
const PIPE_COLORS = {
  '給水': '#2b6cb0', '排水': '#805ad5', '冷温水': '#38a169',
  'ドレン': '#0bc5ea', '電気': '#dd6b20',
};

// 勾配のデフォルト値(分母方式、例: 50 → 1/50 = 2/100 勾配)
// 排水・ドレンは流下方向に勾配が必要なため標準値を設定
const SLOPE_DEFAULTS = { '排水': 50, 'ドレン': 50 };

// ===== 離隔考慮の干渉判定 =====
// 配管種別ごとの保温厚デフォルト値(mm)
// 冷温水・ドレンは結露防止のため保温必須、給水・電気は基本不要、排水も基本不要
// 実務的には現場や仕様書で値が変わるが、ここでは典型値を採用
const INSULATION_DEFAULTS = {
  '給水': 0,
  '排水': 0,
  '冷温水': 25,  // 結露防止+断熱
  'ドレン': 10,  // 結露防止
  '電気': 0,
};

// 配管・ダクトの施工離隔(クリアランス)デフォルト値 mm
// 配管・ダクトの周囲に必要なメンテナンス・施工アクセススペース
// 実務的には50〜150mm程度。デフォルトは50mmを採用(最低限の保守スペース)
const PIPE_CLEARANCE_DEFAULT = 50;
const DUCT_CLEARANCE_DEFAULT = 50;
// 躯体(梁・柱)の周囲離隔は基本0(配管側で離隔を確保する設計が一般的)

// 配管口径の選択肢(JIS規格の代表的なサイズ)
const DIAMETERS = ['φ25', 'φ40', 'φ50', 'φ75', 'φ100', 'φ125'];

// 配管・ダクトのデフォルトレベル(FL+◯◯◯ mm)
// 天井懐(梁下と天井の間)に配管を通すのが標準的なので FL+2500 をデフォルトに
const DEFAULT_PIPE_LEVEL = 2500;

// 初期ビューボックス(SVG の表示範囲)とズーム制限
const INITIAL_VIEW = { x: 0, y: 0, w: 600, h: 560 };
const MIN_ZOOM = 0.25;
const MAX_ZOOM = 8;

// ===== 縮尺の定義 =====
// プロトタイプは「キャンバスのピクセル座標を実寸 mm として扱う」のではなく、
// 縮尺 1px = 25mm として扱う。これにより5000mmスパンの躯体を200pxで描画でき、
// 画面の見やすさと実寸の整合性を両立。
// 距離計算は実寸 mm で行い(distanceMM)、描画はピクセルで行う。
const SCALE_MM_PER_PX = 25;
// スナップ単位は 4px = 100mm に設定(設備設計で典型的に使う寸法ピッチ)
const SNAP_PX = 4;

// ===== アイソメ図(等角投影)用の定数と関数 =====
// 標準的な30度等角投影を使用。
// 視点は3D空間の「右手前上空」(+x方向、+y方向、+z方向の遠方)から見下ろす想定。
// 3D座標 (x, y, z) を画面 (sx, sy) に投影する標準式:
//   sx = (x - y) * cos30°
//   sy = (x + y) * sin30° - z/SCALE  (高さ z はピクセル換算後に画面上方向に展開)
const ISO_COS = Math.cos(Math.PI / 6); // ≈ 0.866
const ISO_SIN = Math.sin(Math.PI / 6); // = 0.5

// 3D点(平面x,y のpx座標、レベルzのmm値)→ アイソメ画面座標(sx, sy)
// 高さ z は SCALE_MM_PER_PX で割ってピクセル単位に揃える
function toIso(px, py, levelMM) {
  const sx = (px - py) * ISO_COS;
  const sy = (px + py) * ISO_SIN - (levelMM / SCALE_MM_PER_PX);
  return { x: sx, y: sy };
}

// 直方体(AABB)の8頂点をアイソメ投影した画面座標を返す
// 頂点の命名規則:
//   b/t = bottom/top(z軸方向、下面/上面)
//   l/r = left/right(平面x軸、小さい/大きい)
//   b/f = back/front(平面y軸、SVG座標系でyが小さい=画面奥、yが大きい=画面手前)
// SVG座標系はYが下方向プラスなので、平面y+hが視点に近い「手前」、平面yが「奥」
function isoBoxVertices(x, y, w, h, bottomFL, topFL) {
  return {
    // 下面4頂点
    blb: toIso(x,     y,     bottomFL), // 左奥
    brb: toIso(x + w, y,     bottomFL), // 右奥
    brf: toIso(x + w, y + h, bottomFL), // 右手前
    blf: toIso(x,     y + h, bottomFL), // 左手前
    // 上面4頂点
    tlb: toIso(x,     y,     topFL),    // 左奥
    trb: toIso(x + w, y,     topFL),    // 右奥
    trf: toIso(x + w, y + h, topFL),    // 右手前
    tlf: toIso(x,     y + h, topFL),    // 左手前
  };
}

// 直方体を画面投影したときの凸包(外周多角形)の頂点列を求める
// 直方体の8頂点をアイソメ投影し、Andrew's monotone chain アルゴリズムで凸包を計算
// 戻り値: [{x, y}, ...] の頂点列(時計回り)
// 用途: 配管が躯体に「画面上で重なっているか」を判定する際の境界として使用
function convexHullOfBox(box) {
  const v = isoBoxVertices(box.x, box.y, box.w, box.h, box.bottomFL, box.topFL);
  const pts = [v.blb, v.brb, v.brf, v.blf, v.tlb, v.trb, v.trf, v.tlf];
  // Andrew's monotone chain による凸包計算
  // 1. 点をx座標(同じならy)でソート
  // 2. 下側の凸包(lower hull)を構築
  // 3. 上側の凸包(upper hull)を構築
  // 4. 結合して全体の凸包を得る
  pts.sort((a, b) => a.x - b.x || a.y - b.y);
  // 外積:o→aと o→b の符号で「左回り or 右回り」を判定
  const cross = (o, a, b) => (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
  const lower = [];
  for (const p of pts) {
    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
      lower.pop();
    }
    lower.push(p);
  }
  const upper = [];
  for (let i = pts.length - 1; i >= 0; i--) {
    const p = pts[i];
    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
      upper.pop();
    }
    upper.push(p);
  }
  lower.pop();
  upper.pop();
  return lower.concat(upper);
}

// 点 (x, y) が多角形 polygon = [{x, y}, ...] の内部にあるかを判定
// ray casting アルゴリズム:
//   点から水平に放った光線が多角形の辺と何回交差するか数え、奇数なら内部
// 用途: 配管が躯体の画面投影内にあるかを判定する隠線処理
function pointInPolygon(pt, polygon) {
  let inside = false;
  // polygon の各辺について判定。j は前の頂点、i は現在の頂点
  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
    const xi = polygon[i].x, yi = polygon[i].y;
    const xj = polygon[j].x, yj = polygon[j].y;
    // 辺(j,i)と水平線(pt.y)の交差判定:
    //   pt.y が辺の y範囲内にあり、かつ pt.x が交点の x座標より小さい場合に光線が辺を横切る
    const intersect = ((yi > pt.y) !== (yj > pt.y)) &&
      (pt.x < (xj - xi) * (pt.y - yi) / (yj - yi + 1e-12) + xi);
    if (intersect) inside = !inside;
  }
  return inside;
}

// 3D線分 vs 軸並行直方体(AABB)の交差区間を slab method で求める
// p1, p2: { x, y, z }(z = 実寸mm のFL+◯◯◯)
// box: { x, y, w, h, bottomFL, topFL }(平面座標はpx、高さはmm)
// 戻り値: [tEnter, tExit](0〜1の媒介変数、交差なしの場合は null)
//
// slab method の原理:
//   軸並行直方体は3組のスラブ(x方向、y方向、z方向の対面2平面)の積集合として表せる
//   線分の媒介変数 t に対して各スラブとの交差区間を計算し、その積集合が直方体との交差区間
//
// 用途:
//   - 干渉判定:配管(線分)が躯体(直方体)を3D空間で貫通するか
//   - 隠線処理:配管区間と躯体の重なり判定
function lineBoxIntersection(p1, p2, box) {
  const dx = p2.x - p1.x;
  const dy = p2.y - p1.y;
  const dz = p2.z - p1.z;
  let tMin = 0;  // 線分の始点(t=0)
  let tMax = 1;  // 線分の終点(t=1)
  // X方向のスラブ:[box.x, box.x + box.w]
  if (Math.abs(dx) < 1e-9) {
    // 線分が X 方向に動かない場合、p1.x が box の x範囲外なら交差なし
    if (p1.x < box.x || p1.x > box.x + box.w) return null;
  } else {
    let t1 = (box.x - p1.x) / dx;
    let t2 = (box.x + box.w - p1.x) / dx;
    if (t1 > t2) { const tmp = t1; t1 = t2; t2 = tmp; }
    tMin = Math.max(tMin, t1);
    tMax = Math.min(tMax, t2);
    if (tMin > tMax) return null;
  }
  // Y方向のスラブ:[box.y, box.y + box.h]
  if (Math.abs(dy) < 1e-9) {
    if (p1.y < box.y || p1.y > box.y + box.h) return null;
  } else {
    let t1 = (box.y - p1.y) / dy;
    let t2 = (box.y + box.h - p1.y) / dy;
    if (t1 > t2) { const tmp = t1; t1 = t2; t2 = tmp; }
    tMin = Math.max(tMin, t1);
    tMax = Math.min(tMax, t2);
    if (tMin > tMax) return null;
  }
  // Z方向(高さ)のスラブ:[box.bottomFL, box.topFL]
  // 注: Z は mm 単位、XY は px 単位だが、tの計算上は単位を気にせず統一的に扱える
  if (Math.abs(dz) < 1e-9) {
    if (p1.z < box.bottomFL || p1.z > box.topFL) return null;
  } else {
    let t1 = (box.bottomFL - p1.z) / dz;
    let t2 = (box.topFL - p1.z) / dz;
    if (t1 > t2) { const tmp = t1; t1 = t2; t2 = tmp; }
    tMin = Math.max(tMin, t1);
    tMax = Math.min(tMax, t2);
    if (tMin > tMax) return null;
  }
  // 線分の範囲 [0, 1] にクリップ
  return [Math.max(0, tMin), Math.min(1, tMax)];
}

// 隠れ区間を統合・ソートして、線分を「可視区間」と「隠れ区間」に分割する
// hiddenIntervals: [[t1, t2], ...] (各区間は 0〜1 の媒介変数)
// 戻り値: { visible: [[t1, t2], ...], hidden: [[t1, t2], ...] }
// (注: 現状はアイソメ描画でペインターズアルゴリズムに移行したため未使用だが、
//  将来の真の隠線処理に再利用できるよう残している)
function splitVisibility(hiddenIntervals) {
  if (hiddenIntervals.length === 0) return { visible: [[0, 1]], hidden: [] };
  // 重なる区間を統合
  const sorted = hiddenIntervals.slice().sort((a, b) => a[0] - b[0]);
  const merged = [sorted[0].slice()];
  for (let i = 1; i < sorted.length; i++) {
    const last = merged[merged.length - 1];
    if (sorted[i][0] <= last[1]) {
      last[1] = Math.max(last[1], sorted[i][1]);
    } else {
      merged.push(sorted[i].slice());
    }
  }
  // 可視区間を計算(隠れ区間の補集合)
  const visible = [];
  let cursor = 0;
  for (const [a, b] of merged) {
    if (a > cursor) visible.push([cursor, a]);
    cursor = b;
  }
  if (cursor < 1) visible.push([cursor, 1]);
  return { visible, hidden: merged };
}

// 色の濃淡を作る関数
// アイソメ図で直方体の3面に明暗をつけて立体感を出すために使用
// 例: shadeColor('#48bb78', 0.7) → 暗めの色(右側面に使用)
//     shadeColor('#48bb78', 1.0) → 元の色(上面に使用)
//     shadeColor('#48bb78', 0.85) → 中間(正面に使用)
function shadeColor(hex, factor) {
  // '#RRGGBB' の各成分を取り出し、factor 倍する(0〜255でクリップ)
  const r = parseInt(hex.substr(1, 2), 16);
  const g = parseInt(hex.substr(3, 2), 16);
  const b = parseInt(hex.substr(5, 2), 16);
  const nr = Math.min(255, Math.max(0, Math.round(r * factor)));
  const ng = Math.min(255, Math.max(0, Math.round(g * factor)));
  const nb = Math.min(255, Math.max(0, Math.round(b * factor)));
  return `#${nr.toString(16).padStart(2, '0')}${ng.toString(16).padStart(2, '0')}${nb.toString(16).padStart(2, '0')}`;
}

