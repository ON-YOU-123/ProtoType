              // 配管とダクトを同じロジックで処理する。違いは:
              //   - 配管:start/endノードは nodes、レベル情報は edgeLevels
              //   - ダクト:start/endノードは ductNodes、レベルは edge.level(単一値)
              //   - 配管の貫通中区間は破線描画、ダクトの貫通中区間は描画スキップ
              const pipeUnits = units.filter(u => u.kind === 'pipe');
              const ductUnits = units.filter(u => u.kind === 'duct');
              // 配管とダクトを統合した「可動ユニット」リスト
