              </div>
            </React.Fragment>
          ) : (
            <React.Fragment>
              <div className="sidebar-section">
                <div className="sidebar-section-title">配管種別</div>
                {PIPE_TYPES.map(type => (
                  <div key={type} className={`sidebar-item ${currentPipeType === type ? 'active' : ''}`} onClick={() => setCurrentPipeType(type)}>
                    <span style={{display: 'inline-block', width: '10px', height: '10px', background: PIPE_COLORS[type], marginRight: '6px', borderRadius: '2px', verticalAlign: 'middle'}}></span>
                    {type}
