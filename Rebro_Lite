        const ductSysRows = summary.ductSystems.map(s => [s.system, s.typesText, s.count, Math.round(s.totalLength)]);
        const wsDuctSys = XLSX.utils.aoa_to_sheet([ductSysHeader, ...ductSysRows]);
        wsDuctSys['!cols'] = [{ wch: 14 }, { wch: 30 }, { wch: 8 }, { wch: 14 }];
